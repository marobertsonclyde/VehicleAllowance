{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Flow 6: President Approval & Payroll Notification. Triggered when va_presidentDecision is set (President Review) OR called directly by Flow 5 for Update/Renewal (skipPresidentStep=true). Creates the va_AllowanceRecord, creates InsuranceReminderSchedule rows, sends Teams payroll notification, confirms approval to employee.",
  "triggers": {
    "When_president_decision_is_set": {
      "type": "OpenApiConnectionWebhook",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "SubscribeWebhookTrigger" },
        "parameters": {
          "subscriptionRequest/message": 3,
          "subscriptionRequest/entityname": "va_allowanceapplication",
          "subscriptionRequest/scope": 4,
          "subscriptionRequest/filterexpression": "va_status eq 720000015 and va_presidentDecision ne null",
          "subscriptionRequest/filteringattributes": "va_presidentDecision"
        }
      }
    },
    "manual_invocation_from_Flow5": {
      "_comment": "Called by Flow 5 when president step is not required. Input: applicationId, skipPresidentStep=true.",
      "type": "Request",
      "kind": "Button",
      "inputs": {
        "schema": {
          "type": "object",
          "properties": {
            "applicationId": { "type": "string" },
            "skipPresidentStep": { "type": "boolean" }
          }
        }
      }
    }
  },
  "actions": {
    "1_Resolve_application_id": {
      "_comment": "Works for both trigger paths: webhook trigger or manual invocation from Flow 5.",
      "type": "Compose",
      "inputs": "@coalesce(triggerOutputs()?['body/va_allowanceapplicationid'], triggerBody()?['applicationId'])"
    },
    "2_Get_application": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@outputs('1_Resolve_application_id')",
          "$select": "va_name,va_applicantName,va_applicantJobTitle,va_applicantCompany,va_personnelNumber,va_allowanceLevel,va_monthlyAllowanceAmount,va_evChargingAllowance,va_totalMonthlyAmount,va_isElectricVehicle,va_presidentDecision,va_presidentNotes"
        }
      }
    },
    "2b_Check_president_approved_or_skip": {
      "_comment": "If triggered by webhook, only proceed if president approved. If invoked by Flow 5 (skip=true), always proceed.",
      "type": "If",
      "expression": {
        "or": [
          { "equals": ["@triggerBody()?['skipPresidentStep']", true] },
          { "equals": ["@outputs('2_Get_application')?['body/va_presidentDecision']", 720000050] }
        ]
      },
      "actions": {
        "3_Calculate_effective_date": {
          "_comment": "15th/16th rule: day <= 15 → first of current month; day >= 16 → first of next month.",
          "type": "Compose",
          "inputs": {
            "effectiveDate": "@if(lessOrEquals(int(formatDateTime(utcNow(), 'dd')), 15), startOfMonth(utcNow()), addMonths(startOfMonth(utcNow()), 1))"
          }
        },
        "4_Calculate_next_renewal_due": {
          "_comment": "Next Aug 1 that is >= 3 months away.",
          "type": "Compose",
          "inputs": {
            "nextRenewalDue": "@if(lessOrEquals(addMonths(utcNow(), 3), concat(formatDateTime(utcNow(), 'yyyy'), '-08-01T00:00:00Z')), concat(formatDateTime(utcNow(), 'yyyy'), '-08-01'), concat(string(add(int(formatDateTime(utcNow(), 'yyyy')), 1)), '-08-01'))"
          }
        },
        "5_Create_AllowanceRecord": {
          "_comment": "The living active record for this recipient. Payroll uses this for payment amounts.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "CreateItem" },
            "parameters": {
              "entityName": "va_allowancerecords",
              "item/va_name": "@{outputs('2_Get_application')?['body/va_personnelNumber']} — @{outputs('2_Get_application')?['body/va_applicantName']} — Level @{outputs('2_Get_application')?['body/va_allowanceLevel']}",
              "item/va_personnelNumber": "@outputs('2_Get_application')?['body/va_personnelNumber']",
              "item/va_allowanceLevel": "@outputs('2_Get_application')?['body/va_allowanceLevel']",
              "item/va_monthlyAllowanceAmount": "@outputs('2_Get_application')?['body/va_monthlyAllowanceAmount']",
              "item/va_evChargingAllowance": "@outputs('2_Get_application')?['body/va_evChargingAllowance']",
              "item/va_totalMonthlyAmount": "@outputs('2_Get_application')?['body/va_totalMonthlyAmount']",
              "item/va_isElectricVehicle": "@outputs('2_Get_application')?['body/va_isElectricVehicle']",
              "item/va_effectiveDate": "@outputs('3_Calculate_effective_date')?['effectiveDate']",
              "item/va_status": 720000400,
              "item/va_applicantName": "@outputs('2_Get_application')?['body/va_applicantName']",
              "item/va_applicantJobTitle": "@outputs('2_Get_application')?['body/va_applicantJobTitle']",
              "item/va_applicantCompany": "@outputs('2_Get_application')?['body/va_applicantCompany']",
              "item/va_nextRenewalDue": "@outputs('4_Calculate_next_renewal_due')?['nextRenewalDue']",
              "item/va_originalApplicationId@odata.bind": "/va_allowanceapplications(@{outputs('1_Resolve_application_id')})"
            }
          }
        },
        "6_Transition_application_to_Payroll_Notification": {
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
            "parameters": {
              "entityName": "va_allowanceapplications",
              "recordId": "@outputs('1_Resolve_application_id')",
              "item/va_status": 720000016,
              "item/va_effectiveDate": "@outputs('3_Calculate_effective_date')?['effectiveDate']",
              "item/va_nextRenewalDue": "@outputs('4_Calculate_next_renewal_due')?['nextRenewalDue']",
              "item/va_presidentApprovalDate": "@utcNow()"
            }
          }
        },
        "7_Get_active_insurance_policies": {
          "_comment": "Get all policies linked to this application to create reminder schedules.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "ListRecords" },
            "parameters": {
              "entityName": "va_insurancepolicies",
              "$filter": "_va_applicationid_value eq '@{outputs('1_Resolve_application_id')}'",
              "$select": "va_insurancepolicyid,va_policyType,va_expirationDate,va_carrierName"
            }
          }
        },
        "7b_Get_reminder_config": {
          "_comment": "Read active reminder intervals from va_ReminderConfig.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "ListRecords" },
            "parameters": {
              "entityName": "va_reminderconfigs",
              "$filter": "va_isActive eq true",
              "$select": "va_reminderDays1,va_reminderDays2,va_reminderDays3,va_gracePeriodDays",
              "$top": 1
            }
          }
        },
        "8_Create_reminder_schedules_for_each_policy": {
          "_comment": "For each active insurance policy, create 5 InsuranceReminderSchedule rows: Reminder1, Reminder2, Reminder3, Expiry, GracePeriod. Dates calculated from policy expiry minus config intervals.",
          "type": "Foreach",
          "foreach": "@outputs('7_Get_active_insurance_policies')?['body/value']",
          "actions": {
            "Mark_policy_as_active": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_insurancepolicies",
                  "recordId": "@items('8_Create_reminder_schedules_for_each_policy')?['va_insurancepolicyid']",
                  "item/va_isActivePolicy": true,
                  "item/va_personnelNumber": "@outputs('2_Get_application')?['body/va_personnelNumber']",
                  "item/va_allowanceRecordId@odata.bind": "/va_allowancerecords(@{outputs('5_Create_AllowanceRecord')?['body/va_allowancerecordid']})"
                }
              }
            },
            "Create_Reminder1_schedule": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "CreateItem" },
                "parameters": {
                  "entityName": "va_insurancereminderschedules",
                  "item/va_name": "@{first(outputs('7b_Get_reminder_config')?['body/value'])?['va_reminderDays1']}-day reminder — @{items('8_Create_reminder_schedules_for_each_policy')?['va_carrierName']} — @{outputs('2_Get_application')?['body/va_personnelNumber']}",
                  "item/va_reminderDate": "@addDays(items('8_Create_reminder_schedules_for_each_policy')?['va_expirationDate'], mul(first(outputs('7b_Get_reminder_config')?['body/value'])?['va_reminderDays1'], -1))",
                  "item/va_reminderType": "Reminder1",
                  "item/va_isSent": false,
                  "item/va_personnelNumber": "@outputs('2_Get_application')?['body/va_personnelNumber']",
                  "item/va_policyId@odata.bind": "/va_insurancepolicies(@{items('8_Create_reminder_schedules_for_each_policy')?['va_insurancepolicyid']})",
                  "item/va_allowanceRecordId@odata.bind": "/va_allowancerecords(@{outputs('5_Create_AllowanceRecord')?['body/va_allowancerecordid']})"
                }
              }
            },
            "Create_Reminder2_schedule": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "CreateItem" },
                "parameters": {
                  "entityName": "va_insurancereminderschedules",
                  "item/va_name": "@{first(outputs('7b_Get_reminder_config')?['body/value'])?['va_reminderDays2']}-day reminder — @{items('8_Create_reminder_schedules_for_each_policy')?['va_carrierName']} — @{outputs('2_Get_application')?['body/va_personnelNumber']}",
                  "item/va_reminderDate": "@addDays(items('8_Create_reminder_schedules_for_each_policy')?['va_expirationDate'], mul(first(outputs('7b_Get_reminder_config')?['body/value'])?['va_reminderDays2'], -1))",
                  "item/va_reminderType": "Reminder2",
                  "item/va_isSent": false,
                  "item/va_personnelNumber": "@outputs('2_Get_application')?['body/va_personnelNumber']",
                  "item/va_policyId@odata.bind": "/va_insurancepolicies(@{items('8_Create_reminder_schedules_for_each_policy')?['va_insurancepolicyid']})",
                  "item/va_allowanceRecordId@odata.bind": "/va_allowancerecords(@{outputs('5_Create_AllowanceRecord')?['body/va_allowancerecordid']})"
                }
              }
            },
            "Create_Reminder3_and_Expiry_Grace": {
              "_comment": "Also create Reminder3 (7-day), Expiry (day-of), and GracePeriod (expiry + graceDays) rows.",
              "type": "Compose",
              "inputs": "_implement: same pattern as Reminder1/2 for Reminder3, Expiry (addDays=0), GracePeriod (addDays=+gracePeriodDays)"
            }
          }
        },
        "9_Send_payroll_Teams_channel_message": {
          "_comment": "Post to the payroll Teams channel. Not an adaptive card — a plain message with all details needed for payroll setup. Include effective date, personnel number, level, monthly amounts.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_teams", "operationId": "PostMessageToChannel" },
            "parameters": {
              "channelId": "@parameters('$connections')['shared_environmentvariable']['va_PayrollTeamsChannelId']",
              "body/messageBody": "<h3>New Vehicle Allowance — Payroll Action Required</h3><table><tr><td><b>Personnel #</b></td><td>@{outputs('2_Get_application')?['body/va_personnelNumber']}</td></tr><tr><td><b>Name</b></td><td>@{outputs('2_Get_application')?['body/va_applicantName']}</td></tr><tr><td><b>Company</b></td><td>@{outputs('2_Get_application')?['body/va_applicantCompany']}</td></tr><tr><td><b>Level</b></td><td>Level @{outputs('2_Get_application')?['body/va_allowanceLevel']}</td></tr><tr><td><b>Monthly Allowance</b></td><td>$@{outputs('2_Get_application')?['body/va_monthlyAllowanceAmount']}/mo</td></tr><tr><td><b>EV Charging</b></td><td>@{if(outputs('2_Get_application')?['body/va_isElectricVehicle'], concat('$', outputs('2_Get_application')?['body/va_evChargingAllowance'], '/mo'), 'N/A')}</td></tr><tr><td><b>Total Monthly</b></td><td>$@{outputs('2_Get_application')?['body/va_totalMonthlyAmount']}/mo</td></tr><tr><td><b>Effective Date</b></td><td>@{outputs('3_Calculate_effective_date')?['effectiveDate']}</td></tr><tr><td><b>Application #</b></td><td>@{outputs('2_Get_application')?['body/va_name']}</td></tr></table>",
              "body/subject": "New Vehicle Allowance — @{outputs('2_Get_application')?['body/va_applicantName']} — @{outputs('2_Get_application')?['body/va_personnelNumber']}"
            }
          }
        },
        "10_Update_application_payroll_notified_and_active": {
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
            "parameters": {
              "entityName": "va_allowanceapplications",
              "recordId": "@outputs('1_Resolve_application_id')",
              "item/va_status": 720000017,
              "item/va_payrollNotifiedDate": "@utcNow()"
            }
          }
        },
        "11_Notify_employee_approved": {
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
            "parameters": {
              "poster": "Flow bot",
              "location": "Chat with Flow bot",
              "body/recipient": "@triggerOutputs()?['body/_ownerid_value']",
              "body/messageBody": "<p>Great news! Your Vehicle Allowance application <strong>@{outputs('2_Get_application')?['body/va_name']}</strong> has been approved. Your allowance of <strong>$@{outputs('2_Get_application')?['body/va_totalMonthlyAmount']}/month</strong> will begin effective <strong>@{outputs('3_Calculate_effective_date')?['effectiveDate']}</strong>. Payroll has been notified.</p>"
            }
          }
        }
      },
      "else": {
        "_comment": "President rejected. Transition to Rejected, notify employee.",
        "actions": {
          "President_rejected_transition": {
            "type": "OpenApiConnection",
            "inputs": {
              "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
              "parameters": {
                "entityName": "va_allowanceapplications",
                "recordId": "@outputs('1_Resolve_application_id')",
                "item/va_status": 720000018,
                "item/va_presidentApprovalDate": "@utcNow()"
              }
            }
          },
          "President_rejected_notify_employee": {
            "type": "OpenApiConnection",
            "inputs": {
              "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
              "parameters": {
                "poster": "Flow bot",
                "location": "Chat with Flow bot",
                "body/recipient": "@triggerOutputs()?['body/_ownerid_value']",
                "body/messageBody": "<p>Your Vehicle Allowance application <strong>@{outputs('2_Get_application')?['body/va_name']}</strong> was not approved. Contact the Equipment Department if you have questions.</p>"
              }
            }
          }
        }
      }
    }
  }
}
