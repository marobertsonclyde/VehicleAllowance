{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Flow 8: Document Upload & AI Processing. Triggered when a new va_Document row is created with va_aiProcessingStatus = Pending (720000020). Handles BOTH initial application uploads and insurance renewal uploads. Classifies document, extracts data, updates linked Policy/Vehicle record, updates DocumentChecklist item, recalculates application AI score. On failure: notifies Equipment Leader.",
  "triggers": {
    "When_document_created_with_Pending_status": {
      "type": "OpenApiConnectionWebhook",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "SubscribeWebhookTrigger" },
        "parameters": {
          "subscriptionRequest/message": 1,
          "subscriptionRequest/entityname": "va_document",
          "subscriptionRequest/scope": 4,
          "subscriptionRequest/filterexpression": "va_aiProcessingStatus eq 720000020"
        }
      }
    }
  },
  "actions": {
    "1_Mark_Processing": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
        "parameters": {
          "entityName": "va_documents",
          "recordId": "@triggerOutputs()?['body/va_documentid']",
          "item/va_aiProcessingStatus": 720000021
        }
      }
    },
    "2_Get_document_details": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
        "parameters": {
          "entityName": "va_documents",
          "recordId": "@triggerOutputs()?['body/va_documentid']",
          "$select": "va_documentid,va_name,va_documentType,va_fileReference,_va_applicationid_value,_va_linkedpolicyid_value,_va_linkedvehicleid_value"
        }
      }
    },
    "3_Get_file_content": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "DownloadFile" },
        "parameters": {
          "entityName": "va_documents",
          "recordId": "@triggerOutputs()?['body/va_documentid']",
          "fileAttributeName": "va_fileReference"
        }
      }
    },
    "4_Classify_document": {
      "_comment": "Run va_DocumentClassifier. Confidence < 0.6 → Unknown type → flag for manual assignment.",
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
        "parameters": {
          "modelId": "va_DocumentClassifier",
          "requestv2/inputs/file": {
            "contentBytes": "@body('3_Get_file_content')",
            "contentType": "@triggerOutputs()?['body/va_fileReference_mimeType']"
          }
        }
      }
    },
    "5_Resolve_document_type": {
      "type": "Compose",
      "inputs": {
        "classifiedType": "@if(greater(body('4_Classify_document')?['responsev2/predictionOutput/classification/confidence'], 0.6), body('4_Classify_document')?['responsev2/predictionOutput/classification/tagName'], 'Unknown')",
        "classifierConfidence": "@body('4_Classify_document')?['responsev2/predictionOutput/classification/confidence']"
      }
    },
    "6_Update_document_type": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
        "parameters": {
          "entityName": "va_documents",
          "recordId": "@triggerOutputs()?['body/va_documentid']",
          "item/va_aiClassification": "@outputs('5_Resolve_document_type')?['classifiedType']",
          "item/va_documentType": "@switch(outputs('5_Resolve_document_type')?['classifiedType'], 'Auto Dec Page', 720000300, 'Umbrella Dec Page', 720000301, 'Window Sticker', 720000302, 'Endorsement', 720000303, 720000304)"
        }
      }
    },
    "7_Branch_extract_by_type": {
      "type": "Switch",
      "expression": "@outputs('5_Resolve_document_type')?['classifiedType']",
      "cases": {
        "Auto_Dec_Page": {
          "case": "Auto Dec Page",
          "actions": {
            "Extract_auto": {
              "_comment": "AI Builder extracts all vehicles on the policy (ListedVehicles array) plus coverage limits. Employees commonly have 2-4 household vehicles on one policy — we must confirm the qualifying vehicle is actually on it.",
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
                "parameters": { "modelId": "va_InsuranceDocumentExtractor", "requestv2/inputs/file": { "contentBytes": "@body('3_Get_file_content')" } }
              }
            },
            "Get_linked_vehicle": {
              "_comment": "Fetch the qualifying vehicle record so we can check its VIN against the policy's listed vehicles.",
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
                "parameters": {
                  "entityName": "va_vehicles",
                  "recordId": "@outputs('2_Get_document_details')?['body/_va_linkedvehicleid_value']",
                  "$select": "va_vin"
                }
              }
            },
            "Resolve_vin_on_policy": {
              "_comment": "Check whether the qualifying VIN appears in the extracted ListedVehicles array. Uses string search as Power Automate does not natively filter JSON arrays from AI Builder output. This is sufficient because VINs are unique 17-character strings with no natural language overlap.",
              "type": "Compose",
              "inputs": {
                "qualifyingVin": "@outputs('Get_linked_vehicle')?['body/va_vin']",
                "listedVehiclesJson": "@string(body('Extract_auto')?['responsev2/predictionOutput/fields/ListedVehicles/value'])",
                "vinFoundOnPolicy": "@contains(string(body('Extract_auto')?['responsev2/predictionOutput/fields/ListedVehicles/value']), outputs('Get_linked_vehicle')?['body/va_vin'])"
              }
            },
            "Validate_and_update_auto_policy": {
              "_comment": "Validate coverage limits AND confirm qualifying vehicle is listed on the policy. meetsLiabilityRequirement is only true when BOTH conditions pass: (1) VIN found on policy, (2) limits meet minimums. This catches the common case where an employee submits a dec page for a different vehicle.",
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_insurancepolicies",
                  "recordId": "@outputs('2_Get_document_details')?['body/_va_linkedpolicyid_value']",
                  "item/va_carrierName": "@body('Extract_auto')?['responsev2/predictionOutput/fields/CarrierName/value']",
                  "item/va_policyNumber": "@body('Extract_auto')?['responsev2/predictionOutput/fields/PolicyNumber/value']",
                  "item/va_expirationDate": "@body('Extract_auto')?['responsev2/predictionOutput/fields/ExpirationDate/value']",
                  "item/va_cslLimit": "@float(body('Extract_auto')?['responsev2/predictionOutput/fields/CSLLimit/value'])",
                  "item/va_bodilyInjuryPerPerson": "@float(body('Extract_auto')?['responsev2/predictionOutput/fields/BIPerPerson/value'])",
                  "item/va_bodilyInjuryPerAccident": "@float(body('Extract_auto')?['responsev2/predictionOutput/fields/BIPerAccident/value'])",
                  "item/va_propertyDamage": "@float(body('Extract_auto')?['responsev2/predictionOutput/fields/PropertyDamage/value'])",
                  "item/va_listedVehicles": "@outputs('Resolve_vin_on_policy')?['listedVehiclesJson']",
                  "item/va_qualifyingVehicleConfirmed": "@outputs('Resolve_vin_on_policy')?['vinFoundOnPolicy']",
                  "item/va_checkedVin": "@outputs('Resolve_vin_on_policy')?['qualifyingVin']",
                  "item/va_meetsLiabilityRequirement": "@and(outputs('Resolve_vin_on_policy')?['vinFoundOnPolicy'], or(greaterOrEquals(float(body('Extract_auto')?['responsev2/predictionOutput/fields/CSLLimit/value']), 500000), and(greaterOrEquals(float(body('Extract_auto')?['responsev2/predictionOutput/fields/BIPerPerson/value']), 250000), greaterOrEquals(float(body('Extract_auto')?['responsev2/predictionOutput/fields/BIPerAccident/value']), 500000), greaterOrEquals(float(body('Extract_auto')?['responsev2/predictionOutput/fields/PropertyDamage/value']), 100000))))",
                  "item/va_aiConfidenceScore": "@body('Extract_auto')?['responsev2/predictionOutput/confidence']"
                }
              }
            }
          }
        },
        "Umbrella_Dec_Page": {
          "case": "Umbrella Dec Page",
          "actions": {
            "Extract_umbrella": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
                "parameters": { "modelId": "va_InsuranceDocumentExtractor", "requestv2/inputs/file": { "contentBytes": "@body('3_Get_file_content')" } }
              }
            },
            "Validate_and_update_umbrella_policy": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_insurancepolicies",
                  "recordId": "@outputs('2_Get_document_details')?['body/_va_linkedpolicyid_value']",
                  "item/va_umbrellaLimit": "@float(body('Extract_umbrella')?['responsev2/predictionOutput/fields/UmbrellaLimit/value'])",
                  "item/va_endorsementType": "@body('Extract_umbrella')?['responsev2/predictionOutput/fields/EndorsementType/value']",
                  "item/va_endorsedEntityName": "@body('Extract_umbrella')?['responsev2/predictionOutput/fields/EndorsedEntityName/value']",
                  "item/va_meetsUmbrellaRequirement": "@or(and(equals(body('Extract_umbrella')?['responsev2/predictionOutput/fields/EndorsementType/value'], 'Additional Insured'), greaterOrEquals(float(body('Extract_umbrella')?['responsev2/predictionOutput/fields/UmbrellaLimit/value']), 1000000)), and(equals(body('Extract_umbrella')?['responsev2/predictionOutput/fields/EndorsementType/value'], 'Additional Interest'), greaterOrEquals(float(body('Extract_umbrella')?['responsev2/predictionOutput/fields/UmbrellaLimit/value']), 2000000)))",
                  "item/va_aiConfidenceScore": "@body('Extract_umbrella')?['responsev2/predictionOutput/confidence']"
                }
              }
            }
          }
        },
        "Window_Sticker": {
          "case": "Window Sticker",
          "actions": {
            "Extract_window_sticker": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
                "parameters": { "modelId": "va_WindowStickerExtractor", "requestv2/inputs/file": { "contentBytes": "@body('3_Get_file_content')" } }
              }
            },
            "Update_vehicle_record": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_vehicles",
                  "recordId": "@outputs('2_Get_document_details')?['body/_va_linkedvehicleid_value']",
                  "item/va_vin": "@body('Extract_window_sticker')?['responsev2/predictionOutput/fields/VIN/value']",
                  "item/va_make": "@body('Extract_window_sticker')?['responsev2/predictionOutput/fields/Make/value']",
                  "item/va_model": "@body('Extract_window_sticker')?['responsev2/predictionOutput/fields/Model/value']",
                  "item/va_year": "@int(body('Extract_window_sticker')?['responsev2/predictionOutput/fields/ModelYear/value'])",
                  "item/va_msrpTotal": "@float(body('Extract_window_sticker')?['responsev2/predictionOutput/fields/TotalMSRP/value'])",
                  "item/va_isElectricVehicle": "@contains(toLower(body('Extract_window_sticker')?['responsev2/predictionOutput/fields/Powertrain/value']), 'electric')",
                  "item/va_aiProcessingStatus": 720000022,
                  "item/va_aiConfidenceScore": "@body('Extract_window_sticker')?['responsev2/predictionOutput/confidence']"
                }
              }
            }
          }
        }
      },
      "default": {
        "_comment": "Unknown document type. Set status to Failed, notify Equipment Leader.",
        "actions": {
          "Notify_equipment_leader_unknown_doc": {
            "type": "OpenApiConnection",
            "inputs": {
              "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
              "parameters": {
                "poster": "Flow bot",
                "location": "Chat with Flow bot",
                "body/recipient": "@parameters('$connections')['shared_environmentvariable']['va_EquipmentLeaderUserId']",
                "body/messageBody": "<p>⚠️ A document uploaded for application could not be classified (confidence below threshold). Manual review required: <a href=\"@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}/admin/documents/@{triggerOutputs()?['body/va_documentid']}\">View Document</a></p>"
              }
            }
          }
        }
      }
    },
    "8_Update_document_ai_extracted_data_and_status": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
        "parameters": {
          "entityName": "va_documents",
          "recordId": "@triggerOutputs()?['body/va_documentid']",
          "item/va_aiExtractedData": "@{string(outputs('7_Branch_extract_by_type'))}",
          "item/va_aiProcessingStatus": 720000022,
          "item/va_uploadedOn": "@utcNow()"
        }
      }
    },
    "9_Find_and_satisfy_checklist_item": {
      "_comment": "Find the DocumentChecklist row matching this document type for the application, mark it satisfied.",
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "ListRecords" },
        "parameters": {
          "entityName": "va_documentchecklists",
          "$filter": "_va_applicationid_value eq '@{outputs('2_Get_document_details')?['body/_va_applicationid_value']}' and va_isSatisfied eq false and contains(va_name, '@{outputs('5_Resolve_document_type')?['classifiedType']}')",
          "$select": "va_documentchecklistid",
          "$top": 1
        }
      }
    },
    "9b_Mark_checklist_satisfied": {
      "type": "If",
      "expression": "@greater(length(outputs('9_Find_and_satisfy_checklist_item')?['body/value']), 0)",
      "actions": {
        "Update_checklist_item": {
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
            "parameters": {
              "entityName": "va_documentchecklists",
              "recordId": "@first(outputs('9_Find_and_satisfy_checklist_item')?['body/value'])?['va_documentchecklistid']",
              "item/va_isSatisfied": true,
              "item/va_satisfiedOn": "@utcNow()",
              "item/va_satisfiedByDocumentId@odata.bind": "/va_documents(@{triggerOutputs()?['body/va_documentid']})"
            }
          }
        }
      }
    },
    "10_Error_handler": {
      "_comment": "Configure this as a runAfter with status Failed on all main steps. Marks document as Failed and notifies Equipment Leader.",
      "type": "Compose",
      "inputs": "_implement: set va_aiProcessingStatus = Failed on document, send Teams message to Equipment Leader with document link and error details."
    }
  }
}
