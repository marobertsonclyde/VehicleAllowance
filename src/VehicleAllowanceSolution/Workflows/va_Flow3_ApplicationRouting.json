{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Flow 3: Application Routing (Child Flow). Decides routing path based on AI score, auto-approval eligibility, and application type. Three paths: (A) Fast-track to Director (AI eligible + Vehicle Update/Renewal), (B) Equipment Leader with AI pre-validated badge (AI eligible + New Opt-In), (C) Equipment Leader with flagged issues (AI not eligible). Sends Teams adaptive card to appropriate reviewer.",
  "triggers": {
    "manual": {
      "type": "Request",
      "kind": "Button",
      "inputs": {
        "schema": {
          "type": "object",
          "properties": {
            "applicationId": { "type": "string" },
            "aiScore": { "type": "number" },
            "aiAutoApprovalEligible": { "type": "boolean" },
            "applicationType": { "type": "integer", "description": "720000000=NewOptIn, 720000001=VehicleUpdate, 720000002=AnnualRenewal" }
          },
          "required": ["applicationId", "aiScore", "aiAutoApprovalEligible", "applicationType"]
        }
      }
    }
  },
  "actions": {
    "1_Get_application_summary": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerBody()?['applicationId']",
          "$select": "va_name,va_applicantName,va_applicantJobTitle,va_applicantCompany,va_applicationType,va_allowanceLevel,va_monthlyAllowanceAmount,va_isElectricVehicle,va_evChargingAllowance,va_aiValidationScore,va_aiExtractionSummary"
        }
      }
    },
    "2_Routing_decision": {
      "_comment": "Three-way routing. Fast-track skips Equipment Leader entirely for Vehicle Update/Renewal when AI-eligible.",
      "type": "If",
      "expression": {
        "and": [
          { "equals": ["@triggerBody()?['aiAutoApprovalEligible']", true] },
          { "not": { "equals": ["@triggerBody()?['applicationType']", 720000000] } }
        ]
      },
      "actions": {
        "Path_A_Fast_Track_to_Director": {
          "_comment": "AI eligible + Vehicle Update or Annual Renewal. Skip Equipment Leader, route directly to Director.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
            "parameters": {
              "entityName": "va_allowanceapplications",
              "recordId": "@triggerBody()?['applicationId']",
              "item/va_status": 720000014
            }
          }
        },
        "Path_A_Notify_Director_Teams_Card": {
          "_comment": "Send Teams adaptive card to Director with AI pre-validated badge and quick approve/return/reject actions.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_teams", "operationId": "PostAdaptiveCard" },
            "parameters": {
              "recipient": "@parameters('$connections')['shared_environmentvariable']['va_DirectorOfEquipmentUserId']",
              "messageBody": {
                "type": "AdaptiveCard",
                "version": "1.4",
                "body": [
                  { "type": "TextBlock", "text": "Vehicle Allowance — Director Review Required", "weight": "Bolder", "size": "Medium" },
                  { "type": "FactSet", "facts": [
                    { "title": "Application", "value": "@{outputs('1_Get_application_summary')?['body/va_name']}" },
                    { "title": "Applicant", "value": "@{outputs('1_Get_application_summary')?['body/va_applicantName']}" },
                    { "title": "Type", "value": "@{if(equals(triggerBody()?['applicationType'], 720000001), 'Vehicle Update', 'Annual Renewal')}" },
                    { "title": "AI Score", "value": "@{triggerBody()?['aiScore']}/100 — AI Pre-Validated ✓" },
                    { "title": "Level", "value": "@{outputs('1_Get_application_summary')?['body/va_allowanceLevel']}" },
                    { "title": "Monthly Amount", "value": "$@{outputs('1_Get_application_summary')?['body/va_monthlyAllowanceAmount']}/mo" }
                  ]},
                  { "type": "ActionSet", "actions": [
                    { "type": "Action.OpenUrl", "title": "Review in Admin App", "url": "@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}/admin/applications/@{triggerBody()?['applicationId']}" }
                  ]}
                ]
              }
            }
          }
        }
      },
      "else": {
        "actions": {
          "2b_Equipment_Leader_routing_decision": {
            "_comment": "AI eligible + New Opt-In → Equipment Leader with AI badge. AI not eligible → Equipment Leader with flagged issues.",
            "type": "If",
            "expression": "@triggerBody()?['aiAutoApprovalEligible']",
            "actions": {
              "Path_B_Equipment_Leader_AI_badge": {
                "type": "OpenApiConnection",
                "inputs": {
                  "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                  "parameters": {
                    "entityName": "va_allowanceapplications",
                    "recordId": "@triggerBody()?['applicationId']",
                    "item/va_status": 720000013
                  }
                }
              },
              "Path_B_Notify_Equipment_Leader_AI_badge": {
                "type": "OpenApiConnection",
                "inputs": {
                  "host": { "connectionName": "shared_teams", "operationId": "PostAdaptiveCard" },
                  "parameters": {
                    "recipient": "@parameters('$connections')['shared_environmentvariable']['va_EquipmentLeaderUserId']",
                    "messageBody": {
                      "type": "AdaptiveCard",
                      "version": "1.4",
                      "body": [
                        { "type": "TextBlock", "text": "New Opt-In — AI Pre-Validated ✓", "weight": "Bolder", "color": "Good" },
                        { "type": "FactSet", "facts": [
                          { "title": "Application", "value": "@{outputs('1_Get_application_summary')?['body/va_name']}" },
                          { "title": "Applicant", "value": "@{outputs('1_Get_application_summary')?['body/va_applicantName']}" },
                          { "title": "Company", "value": "@{outputs('1_Get_application_summary')?['body/va_applicantCompany']}" },
                          { "title": "AI Score", "value": "@{triggerBody()?['aiScore']}/100" },
                          { "title": "Monthly", "value": "$@{outputs('1_Get_application_summary')?['body/va_monthlyAllowanceAmount']}/mo" }
                        ]},
                        { "type": "ActionSet", "actions": [
                          { "type": "Action.OpenUrl", "title": "Review in Admin App", "url": "@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}/admin/applications/@{triggerBody()?['applicationId']}" }
                        ]}
                      ]
                    }
                  }
                }
              }
            },
            "else": {
              "actions": {
                "Path_C_Equipment_Leader_flagged": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                    "parameters": {
                      "entityName": "va_allowanceapplications",
                      "recordId": "@triggerBody()?['applicationId']",
                      "item/va_status": 720000013
                    }
                  }
                },
                "Notify_employee_of_AI_issues": {
                  "_comment": "If AI could not validate all documents, notify the employee to check their documents and re-upload if needed.",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
                    "parameters": {
                      "poster": "Flow bot",
                      "location": "Chat with Flow bot",
                      "body/recipient": "@outputs('1_Get_application_summary')?['body/_ownerid_value']",
                      "body/messageBody": "<p>Your application <strong>@{outputs('1_Get_application_summary')?['body/va_name']}</strong> is under Equipment Leader review. Some documents may need attention — your Equipment Leader will reach out if corrections are needed.</p>"
                    }
                  }
                },
                "Path_C_Notify_Equipment_Leader_flagged": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_teams", "operationId": "PostAdaptiveCard" },
                    "parameters": {
                      "recipient": "@parameters('$connections')['shared_environmentvariable']['va_EquipmentLeaderUserId']",
                      "messageBody": {
                        "type": "AdaptiveCard",
                        "version": "1.4",
                        "body": [
                          { "type": "TextBlock", "text": "New Opt-In — Manual Review Required", "weight": "Bolder", "color": "Warning" },
                          { "type": "TextBlock", "text": "AI score: @{triggerBody()?['aiScore']}/100. One or more documents require manual verification.", "wrap": true },
                          { "type": "FactSet", "facts": [
                            { "title": "Application", "value": "@{outputs('1_Get_application_summary')?['body/va_name']}" },
                            { "title": "Applicant", "value": "@{outputs('1_Get_application_summary')?['body/va_applicantName']}" },
                            { "title": "Company", "value": "@{outputs('1_Get_application_summary')?['body/va_applicantCompany']}" }
                          ]},
                          { "type": "ActionSet", "actions": [
                            { "type": "Action.OpenUrl", "title": "Review in Admin App", "url": "@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}/admin/applications/@{triggerBody()?['applicationId']}" }
                          ]}
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "3_Write_audit_log_routing": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "CreateItem" },
        "parameters": {
          "entityName": "va_auditlogs",
          "item/va_name": "Application routed by AI validation flow",
          "item/va_eventType": "StatusChange",
          "item/va_previousStatus": "AI Review",
          "item/va_newStatus": "@if(and(triggerBody()?['aiAutoApprovalEligible'], not(equals(triggerBody()?['applicationType'], 720000000))), 'Director Review', 'Equipment Leader Review')",
          "item/va_performedByName": "System — AI Validation Flow",
          "item/va_notes": "AI Score: @{triggerBody()?['aiScore']}/100. Auto-approval eligible: @{triggerBody()?['aiAutoApprovalEligible']}.",
          "item/va_eventDate": "@utcNow()",
          "item/va_applicationId@odata.bind": "/va_allowanceapplications(@{triggerBody()?['applicationId']})"
        }
      }
    }
  }
}
