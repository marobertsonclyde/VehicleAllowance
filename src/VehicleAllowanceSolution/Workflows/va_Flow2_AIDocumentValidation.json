{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Flow 2: AI Document Validation (Child Flow). Input: applicationId. Retrieves all va_Document records for the application, runs AI Builder extraction on each in parallel, validates results against insurance requirements, calculates composite AI score, updates application, then calls Flow 3 (routing).",
  "triggers": {
    "manual": {
      "type": "Request",
      "kind": "Button",
      "inputs": {
        "schema": {
          "type": "object",
          "properties": {
            "applicationId": { "type": "string", "description": "GUID of the va_AllowanceApplication record." }
          },
          "required": ["applicationId"]
        }
      }
    }
  },
  "actions": {
    "1_Get_all_documents_for_application": {
      "_comment": "Retrieve all documents linked to this application that need AI processing.",
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "ListRecords" },
        "parameters": {
          "entityName": "va_documents",
          "$filter": "_va_applicationid_value eq '@{triggerBody()?['applicationId']}'",
          "$select": "va_documentid,va_name,va_documentType,va_aiProcessingStatus,va_fileReference"
        }
      }
    },
    "2_Get_application_company_for_endorsement_validation": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerBody()?['applicationId']",
          "$select": "va_applicantCompany,va_applicantName,va_allowanceLevel"
        }
      }
    },
    "3_Get_company_entity_for_endorsement_match": {
      "_comment": "Look up the correct Clyde company entity to validate endorsement names against.",
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "ListRecords" },
        "parameters": {
          "entityName": "va_companyentities",
          "$filter": "va_legalEntityCode eq '@{outputs('2_Get_application_company_for_endorsement_validation')?['body/va_applicantCompany']}' and va_isActive eq true",
          "$select": "va_name,va_endorsementAddress,va_legalEntityCode"
        }
      }
    },
    "4_Process_each_document_parallel": {
      "_comment": "Parallel For Each — process up to 4 documents concurrently. Each branch: classify doc type, invoke appropriate AI Builder model, parse results, update Document and linked Policy/Vehicle records.",
      "type": "Foreach",
      "foreach": "@outputs('1_Get_all_documents_for_application')?['body/value']",
      "actions": {
        "4a_Mark_document_Processing": {
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
            "parameters": {
              "entityName": "va_documents",
              "recordId": "@items('4_Process_each_document_parallel')?['va_documentid']",
              "item/va_aiProcessingStatus": 720000021
            }
          }
        },
        "4b_Get_file_content": {
          "_comment": "Retrieve the file bytes from Dataverse file column for AI Builder input.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "DownloadFile" },
            "parameters": {
              "entityName": "va_documents",
              "recordId": "@items('4_Process_each_document_parallel')?['va_documentid']",
              "fileAttributeName": "va_fileReference"
            }
          }
        },
        "4c_Run_document_classifier": {
          "_comment": "va_DocumentClassifier: classifies into Auto Dec Page / Umbrella Dec Page / Window Sticker / Endorsement / Unknown. Confidence < 0.6 → flags for manual type assignment.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
            "parameters": {
              "organization": "@parameters('$connections')['shared_commondataserviceforapps']['connectionId']",
              "modelId": "va_DocumentClassifier",
              "requestv2/inputs/file": {
                "contentBytes": "@body('4b_Get_file_content')",
                "contentType": "@items('4_Process_each_document_parallel')?['va_fileReference_mimeType']"
              }
            }
          }
        },
        "4d_Switch_on_document_type": {
          "_comment": "Branch on classified document type to call the appropriate extraction model.",
          "type": "Switch",
          "expression": "@if(greater(body('4c_Run_document_classifier')?['responsev2/predictionOutput/classification/confidence'], 0.6), body('4c_Run_document_classifier')?['responsev2/predictionOutput/classification/tagName'], 'Unknown')",
          "cases": {
            "Auto_Dec_Page": {
              "case": "Auto Dec Page",
              "actions": {
                "Extract_insurance_auto": {
                  "_comment": "va_InsuranceDocumentExtractor: extracts carrier, policy#, effective/expiry dates, CSL, BI/PD limits, endorsement type, named additional insured entity.",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
                    "parameters": {
                      "modelId": "va_InsuranceDocumentExtractor",
                      "requestv2/inputs/file": { "contentBytes": "@body('4b_Get_file_content')" }
                    }
                  }
                },
                "Validate_auto_limits": {
                  "_comment": "Validation rules: CSL >= $500K OR (BI/person >= $250K AND BI/accident >= $500K AND PD >= $100K). Fuzzy-match endorsement entity against va_CompanyEntity name.",
                  "type": "Compose",
                  "inputs": {
                    "meetsLiability": "@or(greaterOrEquals(float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/CSLLimit/value']), 500000), and(greaterOrEquals(float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/BIPerPerson/value']), 250000), greaterOrEquals(float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/BIPerAccident/value']), 500000), greaterOrEquals(float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/PropertyDamage/value']), 100000)))",
                    "confidence": "@body('Extract_insurance_auto')?['responsev2/predictionOutput/confidence']"
                  }
                },
                "Update_insurance_policy_auto": {
                  "_comment": "Update the linked va_InsurancePolicy record with extracted values and validation result.",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                    "parameters": {
                      "entityName": "va_insurancepolicies",
                      "recordId": "@items('4_Process_each_document_parallel')?['_va_linkedpolicyid_value']",
                      "item/va_carrierName": "@body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/CarrierName/value']",
                      "item/va_policyNumber": "@body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/PolicyNumber/value']",
                      "item/va_expirationDate": "@body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/ExpirationDate/value']",
                      "item/va_cslLimit": "@float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/CSLLimit/value'])",
                      "item/va_bodilyInjuryPerPerson": "@float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/BIPerPerson/value'])",
                      "item/va_bodilyInjuryPerAccident": "@float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/BIPerAccident/value'])",
                      "item/va_propertyDamage": "@float(body('Extract_insurance_auto')?['responsev2/predictionOutput/fields/PropertyDamage/value'])",
                      "item/va_meetsLiabilityRequirement": "@outputs('Validate_auto_limits')?['meetsLiability']",
                      "item/va_aiConfidenceScore": "@outputs('Validate_auto_limits')?['confidence']",
                      "item/va_aiProcessingStatus": 720000022
                    }
                  }
                }
              }
            },
            "Umbrella_Dec_Page": {
              "case": "Umbrella Dec Page",
              "actions": {
                "Extract_insurance_umbrella": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
                    "parameters": {
                      "modelId": "va_InsuranceDocumentExtractor",
                      "requestv2/inputs/file": { "contentBytes": "@body('4b_Get_file_content')" }
                    }
                  }
                },
                "Validate_umbrella_limits": {
                  "_comment": "Umbrella: >= $1M for Additional Insured, >= $2M for Additional Interest.",
                  "type": "Compose",
                  "inputs": {
                    "meetsUmbrella": "@or(and(equals(body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/EndorsementType/value'], 'Additional Insured'), greaterOrEquals(float(body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/UmbrellaLimit/value']), 1000000)), and(equals(body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/EndorsementType/value'], 'Additional Interest'), greaterOrEquals(float(body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/UmbrellaLimit/value']), 2000000)))",
                    "confidence": "@body('Extract_insurance_umbrella')?['responsev2/predictionOutput/confidence']"
                  }
                },
                "Update_insurance_policy_umbrella": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                    "parameters": {
                      "entityName": "va_insurancepolicies",
                      "recordId": "@items('4_Process_each_document_parallel')?['_va_linkedpolicyid_value']",
                      "item/va_carrierName": "@body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/CarrierName/value']",
                      "item/va_policyNumber": "@body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/PolicyNumber/value']",
                      "item/va_expirationDate": "@body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/ExpirationDate/value']",
                      "item/va_umbrellaLimit": "@float(body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/UmbrellaLimit/value'])",
                      "item/va_endorsementType": "@body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/EndorsementType/value']",
                      "item/va_endorsedEntityName": "@body('Extract_insurance_umbrella')?['responsev2/predictionOutput/fields/EndorsedEntityName/value']",
                      "item/va_meetsUmbrellaRequirement": "@outputs('Validate_umbrella_limits')?['meetsUmbrella']",
                      "item/va_aiConfidenceScore": "@outputs('Validate_umbrella_limits')?['confidence']",
                      "item/va_aiProcessingStatus": 720000022
                    }
                  }
                }
              }
            },
            "Window_Sticker": {
              "case": "Window Sticker",
              "actions": {
                "Extract_window_sticker": {
                  "_comment": "va_WindowStickerExtractor: extracts VIN, Total MSRP, year/make/model/trim, powertrain (EV detection).",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_aibuilder", "operationId": "PredictV2" },
                    "parameters": {
                      "modelId": "va_WindowStickerExtractor",
                      "requestv2/inputs/file": { "contentBytes": "@body('4b_Get_file_content')" }
                    }
                  }
                },
                "Update_vehicle_record": {
                  "_comment": "Update the va_Vehicle linked to this application with extracted values.",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                    "parameters": {
                      "entityName": "va_vehicles",
                      "recordId": "@items('4_Process_each_document_parallel')?['_va_linkedvehicleid_value']",
                      "item/va_vin": "@body('Extract_window_sticker')?['responsev2/predictionOutput/fields/VIN/value']",
                      "item/va_make": "@body('Extract_window_sticker')?['responsev2/predictionOutput/fields/Make/value']",
                      "item/va_model": "@body('Extract_window_sticker')?['responsev2/predictionOutput/fields/Model/value']",
                      "item/va_year": "@int(body('Extract_window_sticker')?['responsev2/predictionOutput/fields/ModelYear/value'])",
                      "item/va_msrpTotal": "@float(body('Extract_window_sticker')?['responsev2/predictionOutput/fields/TotalMSRP/value'])",
                      "item/va_isElectricVehicle": "@contains(toLower(body('Extract_window_sticker')?['responsev2/predictionOutput/fields/Powertrain/value']), 'electric')",
                      "item/va_aiProcessingStatus": 720000022,
                      "item/va_aiConfidenceScore": "@body('Extract_window_sticker')?['responsev2/predictionOutput/confidence']"
                    }
                  }
                }
              }
            }
          },
          "default": {
            "_comment": "Unknown document type — confidence below threshold. Set document type to Unknown, notify Equipment Leader.",
            "actions": {
              "Mark_document_unknown": {
                "type": "OpenApiConnection",
                "inputs": {
                  "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                  "parameters": {
                    "entityName": "va_documents",
                    "recordId": "@items('4_Process_each_document_parallel')?['va_documentid']",
                    "item/va_documentType": 720000304,
                    "item/va_aiProcessingStatus": 720000023
                  }
                }
              }
            }
          }
        },
        "4e_Update_document_with_extracted_data_and_checklist": {
          "_comment": "Write va_aiExtractedData JSON and confidence score to the document record. Update the corresponding DocumentChecklist item to satisfied.",
          "type": "OpenApiConnection",
          "inputs": {
            "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
            "parameters": {
              "entityName": "va_documents",
              "recordId": "@items('4_Process_each_document_parallel')?['va_documentid']",
              "item/va_aiExtractedData": "@{string(body('4d_Switch_on_document_type'))}",
              "item/va_aiProcessingStatus": 720000022
            }
          }
        }
      },
      "runtimeConfiguration": {
        "concurrency": { "repetitions": 4 }
      }
    },
    "5_Calculate_composite_AI_score": {
      "_comment": "Average confidence scores across all successfully processed documents. Check all required validation flags. Score 0-100.",
      "type": "Compose",
      "inputs": {
        "_note": "Implement: retrieve all policies for application, check va_meetsLiabilityRequirement and va_meetsUmbrellaRequirement. Average confidence scores * 100. Set va_aiAutoApprovalEligible = true if score >= va_AIAutoApprovalThreshold AND all flags pass.",
        "compositeScore": 0,
        "autoApprovalEligible": false
      }
    },
    "6_Update_application_with_AI_results": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerBody()?['applicationId']",
          "item/va_aiValidationScore": "@outputs('5_Calculate_composite_AI_score')?['compositeScore']",
          "item/va_aiAutoApprovalEligible": "@outputs('5_Calculate_composite_AI_score')?['autoApprovalEligible']"
        }
      }
    },
    "7_Trigger_Flow3_Application_Routing": {
      "_comment": "Pass routing inputs to Flow 3. Flow 3 decides: fast-track to Director, Equipment Leader with AI badge, or Equipment Leader with flags.",
      "type": "Workflow",
      "inputs": {
        "host": { "workflowReferenceName": "va_Flow3_ApplicationRouting" },
        "body": {
          "applicationId": "@triggerBody()?['applicationId']",
          "aiScore": "@outputs('5_Calculate_composite_AI_score')?['compositeScore']",
          "aiAutoApprovalEligible": "@outputs('5_Calculate_composite_AI_score')?['autoApprovalEligible']",
          "applicationType": "@triggerOutputs()?['body/va_applicationType']"
        }
      }
    }
  }
}
