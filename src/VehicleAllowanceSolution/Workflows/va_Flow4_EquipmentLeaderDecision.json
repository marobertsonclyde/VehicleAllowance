{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Flow 4: Equipment Leader Decision. Triggered when va_equipmentLeaderDecision is set while status = Equipment Leader Review. Branches on Approved / Returned / Rejected. All notifications via Teams. Draft messages generated by va_EmailDraftingPrompt AI model for human confirmation before send.",
  "triggers": {
    "When_equipment_leader_decision_is_set": {
      "type": "OpenApiConnectionWebhook",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "SubscribeWebhookTrigger" },
        "parameters": {
          "subscriptionRequest/message": 3,
          "subscriptionRequest/entityname": "va_allowanceapplication",
          "subscriptionRequest/scope": 4,
          "subscriptionRequest/filterexpression": "va_status eq 720000013 and va_equipmentLeaderDecision ne null",
          "subscriptionRequest/filteringattributes": "va_equipmentLeaderDecision"
        }
      }
    }
  },
  "actions": {
    "1_Get_application": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
          "$select": "va_name,va_applicantName,va_applicantCompany,va_applicationType,va_allowanceLevel,va_monthlyAllowanceAmount,va_equipmentLeaderDecision,va_equipmentLeaderNotes,va_aiAutoApprovalEligible"
        }
      }
    },
    "2_Set_review_date": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
          "item/va_equipmentLeaderReviewDate": "@utcNow()"
        }
      }
    },
    "3_Branch_on_decision": {
      "type": "Switch",
      "expression": "@outputs('1_Get_application')?['body/va_equipmentLeaderDecision']",
      "cases": {
        "Approved": {
          "case": 720000010,
          "actions": {
            "Approved_transition_to_Director_Review": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_allowanceapplications",
                  "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
                  "item/va_status": 720000014
                }
              }
            },
            "Approved_notify_Director_Teams_card": {
              "_comment": "Adaptive card to Director with application summary. Director reviews in admin app and sets va_directorDecision.",
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_teams", "operationId": "PostAdaptiveCard" },
                "parameters": {
                  "recipient": "@parameters('$connections')['shared_environmentvariable']['va_DirectorOfEquipmentUserId']",
                  "messageBody": {
                    "type": "AdaptiveCard",
                    "version": "1.4",
                    "body": [
                      { "type": "TextBlock", "text": "Vehicle Allowance — Director Review", "weight": "Bolder" },
                      { "type": "TextBlock", "text": "Equipment Leader approved. Your review is next.", "wrap": true },
                      { "type": "FactSet", "facts": [
                        { "title": "Application", "value": "@{outputs('1_Get_application')?['body/va_name']}" },
                        { "title": "Applicant", "value": "@{outputs('1_Get_application')?['body/va_applicantName']}" },
                        { "title": "Type", "value": "@{outputs('1_Get_application')?['body/va_applicationType']}" },
                        { "title": "AI Pre-Validated", "value": "@{if(outputs('1_Get_application')?['body/va_aiAutoApprovalEligible'], 'Yes ✓', 'No — manual review required')}" },
                        { "title": "Monthly Amount", "value": "$@{outputs('1_Get_application')?['body/va_monthlyAllowanceAmount']}/mo" }
                      ]},
                      { "type": "ActionSet", "actions": [
                        { "type": "Action.OpenUrl", "title": "Open in Admin App", "url": "@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}/admin/applications/@{triggerOutputs()?['body/va_allowanceapplicationid']}" }
                      ]}
                    ]
                  }
                }
              }
            }
          }
        },
        "Returned": {
          "case": 720000011,
          "actions": {
            "Returned_transition_status": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_allowanceapplications",
                  "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
                  "item/va_status": 720000019
                }
              }
            },
            "Returned_notify_employee_Teams": {
              "_comment": "Notify employee their application was returned with Equipment Leader notes.",
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
                "parameters": {
                  "poster": "Flow bot",
                  "location": "Chat with Flow bot",
                  "body/recipient": "@triggerOutputs()?['body/_ownerid_value']",
                  "body/messageBody": "<p><strong>Action Required:</strong> Your application <strong>@{outputs('1_Get_application')?['body/va_name']}</strong> has been returned for corrections. <br/>Notes: @{outputs('1_Get_application')?['body/va_equipmentLeaderNotes']}<br/><a href=\"@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}\">Upload corrected documents</a></p>"
                }
              }
            }
          }
        },
        "Rejected": {
          "case": 720000012,
          "actions": {
            "Rejected_transition_status": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_allowanceapplications",
                  "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
                  "item/va_status": 720000018
                }
              }
            },
            "Rejected_notify_employee_Teams": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
                "parameters": {
                  "poster": "Flow bot",
                  "location": "Chat with Flow bot",
                  "body/recipient": "@triggerOutputs()?['body/_ownerid_value']",
                  "body/messageBody": "<p>Your Vehicle Allowance application <strong>@{outputs('1_Get_application')?['body/va_name']}</strong> has been rejected. @{outputs('1_Get_application')?['body/va_equipmentLeaderNotes']}<br/>Contact the Equipment Department if you have questions.</p>"
                }
              }
            }
          }
        }
      }
    },
    "4_Write_audit_log": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "CreateItem" },
        "parameters": {
          "entityName": "va_auditlogs",
          "item/va_name": "Equipment Leader decision: @{outputs('1_Get_application')?['body/va_equipmentLeaderDecision']}",
          "item/va_eventType": "DecisionMade",
          "item/va_previousStatus": "Equipment Leader Review",
          "item/va_newStatus": "@switch(outputs('1_Get_application')?['body/va_equipmentLeaderDecision'], 720000010, 'Director Review', 720000011, 'Returned to Employee', 720000012, 'Rejected')",
          "item/va_performedByName": "Equipment Leader",
          "item/va_notes": "@outputs('1_Get_application')?['body/va_equipmentLeaderNotes']",
          "item/va_eventDate": "@utcNow()",
          "item/va_applicationId@odata.bind": "/va_allowanceapplications(@{triggerOutputs()?['body/va_allowanceapplicationid']})"
        }
      }
    }
  }
}
