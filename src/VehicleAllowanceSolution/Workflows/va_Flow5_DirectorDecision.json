{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Flow 5: Director Decision. Triggered when va_directorDecision is set while status = Director Review. Key split: Approved + New Opt-In → look up company-specific president (va_CompanyEntity.va_presidentUserId) and route to President Review. Approved + Update/Renewal → skip President, go directly to Flow 6 (Payroll). Returned/Rejected → Teams notification to employee.",
  "triggers": {
    "When_director_decision_is_set": {
      "type": "OpenApiConnectionWebhook",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "SubscribeWebhookTrigger" },
        "parameters": {
          "subscriptionRequest/message": 3,
          "subscriptionRequest/entityname": "va_allowanceapplication",
          "subscriptionRequest/scope": 4,
          "subscriptionRequest/filterexpression": "va_status eq 720000014 and va_directorDecision ne null",
          "subscriptionRequest/filteringattributes": "va_directorDecision"
        }
      }
    }
  },
  "actions": {
    "1_Get_application": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "GetItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
          "$select": "va_name,va_applicantName,va_applicantCompany,va_applicationType,va_allowanceLevel,va_monthlyAllowanceAmount,va_totalMonthlyAmount,va_isElectricVehicle,va_evChargingAllowance,va_directorDecision,va_directorNotes,va_presidentApprovalRequired"
        }
      }
    },
    "2_Set_director_review_date": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
        "parameters": {
          "entityName": "va_allowanceapplications",
          "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
          "item/va_directorReviewDate": "@utcNow()"
        }
      }
    },
    "3_Branch_on_decision": {
      "type": "Switch",
      "expression": "@outputs('1_Get_application')?['body/va_directorDecision']",
      "cases": {
        "Approved": {
          "case": 720000010,
          "actions": {
            "3a_Check_if_president_required": {
              "type": "If",
              "expression": "@outputs('1_Get_application')?['body/va_presidentApprovalRequired']",
              "actions": {
                "3a_i_Lookup_company_president": {
                  "_comment": "Find the company entity for the applicant's company to get the company-specific president.",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "ListRecords" },
                    "parameters": {
                      "entityName": "va_companyentities",
                      "$filter": "va_legalEntityCode eq '@{outputs('1_Get_application')?['body/va_applicantCompany']}' and va_isActive eq true",
                      "$select": "va_presidentUserId,va_presidentName,va_name"
                    }
                  }
                },
                "3a_ii_Set_president_or_fallback": {
                  "_comment": "Use company-specific president if found; fall back to env var va_CompanyPresidentUserId.",
                  "type": "Compose",
                  "inputs": {
                    "presidentUserId": "@if(greater(length(outputs('3a_i_Lookup_company_president')?['body/value']), 0), first(outputs('3a_i_Lookup_company_president')?['body/value'])?['va_presidentUserId'], parameters('$connections')['shared_environmentvariable']['va_CompanyPresidentUserId'])",
                    "presidentName": "@if(greater(length(outputs('3a_i_Lookup_company_president')?['body/value']), 0), first(outputs('3a_i_Lookup_company_president')?['body/value'])?['va_presidentName'], 'Company President')"
                  }
                },
                "3a_iii_Transition_to_President_Review": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                    "parameters": {
                      "entityName": "va_allowanceapplications",
                      "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
                      "item/va_status": 720000015
                    }
                  }
                },
                "3a_iv_Notify_President_Teams_Card": {
                  "_comment": "Send Teams adaptive card to the SPECIFIC subsidiary president. They approve/reject in the admin app.",
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": { "connectionName": "shared_teams", "operationId": "PostAdaptiveCard" },
                    "parameters": {
                      "recipient": "@outputs('3a_ii_Set_president_or_fallback')?['presidentUserId']",
                      "messageBody": {
                        "type": "AdaptiveCard",
                        "version": "1.4",
                        "body": [
                          { "type": "TextBlock", "text": "Vehicle Allowance — President Approval Required", "weight": "Bolder", "size": "Medium" },
                          { "type": "TextBlock", "text": "New opt-in approved by Equipment Leader and Director. Final sign-off required.", "wrap": true },
                          { "type": "FactSet", "facts": [
                            { "title": "Application", "value": "@{outputs('1_Get_application')?['body/va_name']}" },
                            { "title": "Applicant", "value": "@{outputs('1_Get_application')?['body/va_applicantName']}" },
                            { "title": "Company", "value": "@{outputs('1_Get_application')?['body/va_applicantCompany']}" },
                            { "title": "Allowance Level", "value": "Level @{outputs('1_Get_application')?['body/va_allowanceLevel']}" },
                            { "title": "Monthly Allowance", "value": "$@{outputs('1_Get_application')?['body/va_monthlyAllowanceAmount']}/mo" },
                            { "title": "EV Charging", "value": "@{if(outputs('1_Get_application')?['body/va_isElectricVehicle'], concat('$', outputs('1_Get_application')?['body/va_evChargingAllowance'], '/mo ⚡'), 'N/A')}" },
                            { "title": "Total Monthly", "value": "$@{outputs('1_Get_application')?['body/va_totalMonthlyAmount']}/mo" }
                          ]},
                          { "type": "ActionSet", "actions": [
                            { "type": "Action.OpenUrl", "title": "Review & Approve in Admin App", "url": "@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}/admin/applications/@{triggerOutputs()?['body/va_allowanceapplicationid']}" }
                          ]}
                        ]
                      }
                    }
                  }
                }
              },
              "else": {
                "_comment": "No president required (Vehicle Update / Annual Renewal). Invoke Flow 6 directly.",
                "actions": {
                  "3a_v_Trigger_Flow6_Payroll": {
                    "type": "Workflow",
                    "inputs": {
                      "host": { "workflowReferenceName": "va_Flow6_PresidentApprovalPayroll" },
                      "body": { "applicationId": "@triggerOutputs()?['body/va_allowanceapplicationid']", "skipPresidentStep": true }
                    }
                  }
                }
              }
            }
          }
        },
        "Returned": {
          "case": 720000011,
          "actions": {
            "Returned_transition_status": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_allowanceapplications",
                  "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
                  "item/va_status": 720000019
                }
              }
            },
            "Returned_notify_employee": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
                "parameters": {
                  "poster": "Flow bot",
                  "location": "Chat with Flow bot",
                  "body/recipient": "@triggerOutputs()?['body/_ownerid_value']",
                  "body/messageBody": "<p><strong>Action Required:</strong> Your application <strong>@{outputs('1_Get_application')?['body/va_name']}</strong> has been returned by the Director. @{outputs('1_Get_application')?['body/va_directorNotes']}<br/><a href=\"@{parameters('$connections')['shared_environmentvariable']['va_PortalUrl']}\">Upload corrected documents</a></p>"
                }
              }
            }
          }
        },
        "Rejected": {
          "case": 720000012,
          "actions": {
            "Rejected_transition_status": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "UpdateItem" },
                "parameters": {
                  "entityName": "va_allowanceapplications",
                  "recordId": "@triggerOutputs()?['body/va_allowanceapplicationid']",
                  "item/va_status": 720000018
                }
              }
            },
            "Rejected_notify_employee": {
              "type": "OpenApiConnection",
              "inputs": {
                "host": { "connectionName": "shared_teams", "operationId": "PostMessageToConversation" },
                "parameters": {
                  "poster": "Flow bot",
                  "location": "Chat with Flow bot",
                  "body/recipient": "@triggerOutputs()?['body/_ownerid_value']",
                  "body/messageBody": "<p>Your Vehicle Allowance application <strong>@{outputs('1_Get_application')?['body/va_name']}</strong> has not been approved. @{outputs('1_Get_application')?['body/va_directorNotes']}<br/>Contact the Equipment Department if you have questions.</p>"
                }
              }
            }
          }
        }
      }
    },
    "4_Write_audit_log": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": { "connectionName": "shared_commondataserviceforapps", "operationId": "CreateItem" },
        "parameters": {
          "entityName": "va_auditlogs",
          "item/va_name": "Director decision: @{outputs('1_Get_application')?['body/va_directorDecision']}",
          "item/va_eventType": "DecisionMade",
          "item/va_previousStatus": "Director Review",
          "item/va_newStatus": "@switch(outputs('1_Get_application')?['body/va_directorDecision'], 720000010, if(outputs('1_Get_application')?['body/va_presidentApprovalRequired'], 'President Review', 'Payroll Notification'), 720000011, 'Returned to Employee', 720000012, 'Rejected')",
          "item/va_performedByName": "Director of Equipment",
          "item/va_notes": "@outputs('1_Get_application')?['body/va_directorNotes']",
          "item/va_eventDate": "@utcNow()",
          "item/va_applicationId@odata.bind": "/va_allowanceapplications(@{triggerOutputs()?['body/va_allowanceapplicationid']})"
        }
      }
    }
  }
}
