<?xml version="1.0" encoding="utf-8"?>
<!--
  Main form for va_AllowanceRecord.
  Used by Equipment Leaders and Admins to view active allowances and process terminations.
  The "Terminate Allowance" command bar button sets va_status, va_terminationType,
  va_terminationDate, and va_terminationReason then saves the record.
-->
<form>
  <formid>va-allowancerecord-mainform</formid>
  <name>Allowance Record</name>
  <objecttypecode>va_allowancerecord</objecttypecode>
  <type>2</type>
  <formactivationstate>1</formactivationstate>

  <header>
    <rows>
      <row>
        <cell id="hdr_status" showlabel="true">
          <labels><label description="Status" languagecode="1033" /></labels>
          <control id="va_status" classid="{0D2C745A-A054-4A1E-8453-B8AC03BFEB3B}" datafieldname="va_status" />
        </cell>
        <cell id="hdr_level" showlabel="true">
          <labels><label description="Level" languagecode="1033" /></labels>
          <control id="va_allowanceLevel" classid="{0D2C745A-A054-4A1E-8453-B8AC03BFEB3B}" datafieldname="va_allowanceLevel" />
        </cell>
        <cell id="hdr_monthly" showlabel="true">
          <labels><label description="Monthly Amount" languagecode="1033" /></labels>
          <control id="va_monthlyAllowanceAmount" classid="{AA987274-CE4E-4271-A803-66164311A958}" datafieldname="va_monthlyAllowanceAmount" />
        </cell>
      </row>
    </rows>
  </header>

  <tabs>

    <!-- ─── TAB 1: Recipient ─── -->
    <tab name="tab_recipient" expanded="true" showlabel="true" locklevel="0">
      <labels><label description="Recipient" languagecode="1033" /></labels>
      <columns>
        <column width="50%">
          <sections>
            <section name="sec_employee" showlabel="true" locklevel="0">
              <labels><label description="Employee" languagecode="1033" /></labels>
              <rows>
                <row>
                  <cell id="cell_applicantName" showlabel="true">
                    <labels><label description="Name" languagecode="1033" /></labels>
                    <control id="va_applicantName" classid="{4273B735-4538-468D-8F6F-7F4E3D4C1E85}" datafieldname="va_applicantName" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_personnelNumber" showlabel="true">
                    <labels><label description="Personnel #" languagecode="1033" /></labels>
                    <control id="va_personnelNumber" classid="{4273B735-4538-468D-8F6F-7F4E3D4C1E85}" datafieldname="va_personnelNumber" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_company" showlabel="true">
                    <labels><label description="Company" languagecode="1033" /></labels>
                    <control id="va_applicantCompany" classid="{4273B735-4538-468D-8F6F-7F4E3D4C1E85}" datafieldname="va_applicantCompany" />
                  </cell>
                </row>
              </rows>
            </section>
          </sections>
        </column>

        <column width="50%">
          <sections>
            <section name="sec_allowance" showlabel="true" locklevel="0">
              <labels><label description="Allowance Details" languagecode="1033" /></labels>
              <rows>
                <row>
                  <cell id="cell_effectiveDate" showlabel="true">
                    <labels><label description="Effective Date" languagecode="1033" /></labels>
                    <control id="va_effectiveDate" classid="{5B773807-9FB2-42DB-97C3-7A91EFF8B7D8}" datafieldname="va_effectiveDate" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_renewalDue" showlabel="true">
                    <labels><label description="Next Renewal Due" languagecode="1033" /></labels>
                    <control id="va_nextRenewalDue" classid="{5B773807-9FB2-42DB-97C3-7A91EFF8B7D8}" datafieldname="va_nextRenewalDue" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_isEV" showlabel="true">
                    <labels><label description="Electric Vehicle" languagecode="1033" /></labels>
                    <control id="va_isElectricVehicle" classid="{B0C6723A-8503-4FD7-BB28-C8A06AC933C2}" datafieldname="va_isElectricVehicle" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_evCharging" showlabel="true">
                    <labels><label description="EV Charging Allowance" languagecode="1033" /></labels>
                    <control id="va_evChargingAllowance" classid="{AA987274-CE4E-4271-A803-66164311A958}" datafieldname="va_evChargingAllowance" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_assetId" showlabel="true">
                    <labels><label description="Dynamics Asset ID" languagecode="1033" /></labels>
                    <control id="va_dynamicsAssetId" classid="{4273B735-4538-468D-8F6F-7F4E3D4C1E85}" datafieldname="va_dynamicsAssetId" />
                  </cell>
                </row>
              </rows>
            </section>
          </sections>
        </column>
      </columns>
    </tab>

    <!-- ─── TAB 2: Insurance ─── -->
    <tab name="tab_insurance" expanded="false" showlabel="true" locklevel="0">
      <labels><label description="Insurance" languagecode="1033" /></labels>
      <columns>
        <column width="100%">
          <sections>
            <section name="sec_policies" showlabel="false" locklevel="0">
              <labels><label description="" languagecode="1033" /></labels>
              <rows>
                <row>
                  <cell id="cell_policies_grid" showlabel="false" colspan="2">
                    <control id="InsurancePolicies" classid="{E7A81278-8635-4D9E-8D4D-59480B391C5B}" datafieldname="" uniqueid="{sg-policies}">
                      <parameters>
                        <TargetEntityType>va_insurancepolicy</TargetEntityType>
                        <RelationshipName>va_allowancerecord_va_insurancepolicy</RelationshipName>
                        <RecordsPerPage>5</RecordsPerPage>
                        <EnableViewPicker>false</EnableViewPicker>
                      </parameters>
                    </control>
                  </cell>
                </row>
              </rows>
            </section>
          </sections>
        </column>
      </columns>
    </tab>

    <!-- ─── TAB 3: Termination ─── -->
    <!-- Populated by the "Terminate Allowance" command bar action.
         Visible to Equipment Leaders and Admins only (security role).
         Fields are read-only until the termination command is invoked. -->
    <tab name="tab_termination" expanded="false" showlabel="true" locklevel="0">
      <labels><label description="Termination" languagecode="1033" /></labels>
      <columns>
        <column width="50%">
          <sections>
            <section name="sec_termination" showlabel="true" locklevel="0">
              <labels><label description="Termination Details" languagecode="1033" /></labels>
              <rows>
                <row>
                  <cell id="cell_terminationType" showlabel="true">
                    <labels><label description="Termination Type" languagecode="1033" /></labels>
                    <control id="va_terminationType" classid="{0D2C745A-A054-4A1E-8453-B8AC03BFEB3B}" datafieldname="va_terminationType" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_terminationDate" showlabel="true">
                    <labels><label description="Termination Date" languagecode="1033" /></labels>
                    <control id="va_terminationDate" classid="{5B773807-9FB2-42DB-97C3-7A91EFF8B7D8}" datafieldname="va_terminationDate" />
                  </cell>
                </row>
                <row>
                  <cell id="cell_terminationReason" showlabel="true">
                    <labels><label description="Termination Reason" languagecode="1033" /></labels>
                    <control id="va_terminationReason" classid="{E0DECE4B-6FC8-4A8F-A065-082708572369}" datafieldname="va_terminationReason" />
                  </cell>
                </row>
              </rows>
            </section>
          </sections>
        </column>
      </columns>
    </tab>

  </tabs>
</form>
