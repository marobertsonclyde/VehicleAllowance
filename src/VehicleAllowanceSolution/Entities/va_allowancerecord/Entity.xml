<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name LocalizedName="Allowance Record" OriginalName="va_allowancerecord">va_allowancerecord</Name>
  <EntityInfo>
    <entity Name="va_allowancerecord">
      <LocalizedNames>
        <LocalizedName description="Allowance Record" languagecode="1033" />
      </LocalizedNames>
      <LocalizedCollectionNames>
        <LocalizedCollectionName description="Allowance Records" languagecode="1033" />
      </LocalizedCollectionNames>
      <Descriptions>
        <Description description="Living active record for an approved allowance recipient. Created by Flow 6 after final approval. Separate from the application record so the application history is preserved. Linked to active insurance policies and drives the reminder schedule." languagecode="1033" />
      </Descriptions>
      <ownership>UserOwned</ownership>
      <lookupcollectionname>va_allowancerecords</lookupcollectionname>
      <primaryattribute>va_name</primaryattribute>
      <IsActivity>0</IsActivity>
      <IsAuditEnabled>1</IsAuditEnabled>
      <IsAvailableOffline>0</IsAvailableOffline>
      <IsDocumentManagementEnabled>0</IsDocumentManagementEnabled>
      <IsQuickCreateEnabled>0</IsQuickCreateEnabled>
      <IsVisibleInMobile>0</IsVisibleInMobile>
      <attributes>

        <!-- Primary Name -->
        <attribute PhysicalName="va_name">
          <Type>String</Type>
          <Name>va_name</Name>
          <LogicalName>va_name</LogicalName>
          <RequiredLevel>SystemRequired</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Record Name" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Display name formatted as: PersonnelNumber — Name — Level (e.g., P12345 — John Smith — Level A)." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Personnel Number (primary employee key) -->
        <attribute PhysicalName="va_personnelNumber">
          <Type>String</Type>
          <Name>va_personnelNumber</Name>
          <LogicalName>va_personnelNumber</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MaxLength>50</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Personnel Number" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Primary employee business key from Dynamics HR. Used to tie the allowance record to Dynamics for payroll processing." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Allowance Level -->
        <attribute PhysicalName="va_allowanceLevel">
          <Type>Picklist</Type>
          <Name>va_allowanceLevel</Name>
          <LogicalName>va_allowanceLevel</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Allowance Level" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_allowancelevel">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- Monthly Allowance Amount (stored at approval time) -->
        <attribute PhysicalName="va_monthlyAllowanceAmount">
          <Type>Money</Type>
          <Name>va_monthlyAllowanceAmount</Name>
          <LogicalName>va_monthlyAllowanceAmount</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>10000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Monthly Allowance Amount" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Monthly allowance amount stored at the time of approval (from va_AllowanceLevelConfig). Updated manually when CCI adjusts rates." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- EV Charging Allowance -->
        <attribute PhysicalName="va_evChargingAllowance">
          <Type>Money</Type>
          <Name>va_evChargingAllowance</Name>
          <LogicalName>va_evChargingAllowance</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="EV Charging Allowance" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Total Monthly Amount -->
        <attribute PhysicalName="va_totalMonthlyAmount">
          <Type>Money</Type>
          <Name>va_totalMonthlyAmount</Name>
          <LogicalName>va_totalMonthlyAmount</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>15000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Total Monthly Amount" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Is Electric Vehicle -->
        <attribute PhysicalName="va_isElectricVehicle">
          <Type>Boolean</Type>
          <Name>va_isElectricVehicle</Name>
          <LogicalName>va_isElectricVehicle</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Is Electric Vehicle" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="If true, recipient receives EV charging allowance and no fuel card." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — Electric Vehicle" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- Effective Date -->
        <attribute PhysicalName="va_effectiveDate">
          <Type>DateTime</Type>
          <Name>va_effectiveDate</Name>
          <LogicalName>va_effectiveDate</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Effective Date" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Date allowance payments begin. Calculated by Flow 6 using the 15th/16th rule." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Status -->
        <attribute PhysicalName="va_status">
          <Type>Picklist</Type>
          <Name>va_status</Name>
          <LogicalName>va_status</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Record Status" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_allowancerecordstatus">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000400">
                <Labels><Label description="Active" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000401">
                <Labels><Label description="Suspended" languagecode="1033" /></Labels>
                <Descriptions><Description description="Temporarily suspended pending document compliance." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000402">
                <Labels><Label description="Terminated" languagecode="1033" /></Labels>
                <Descriptions><Description description="Allowance terminated (opt-out, non-compliance, or termination of employment)." languagecode="1033" /></Descriptions>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- Original Application Lookup -->
        <attribute PhysicalName="va_originalApplicationId">
          <Type>Lookup</Type>
          <Name>va_originalApplicationId</Name>
          <LogicalName>va_originalApplicationId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Original Application" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="The application that created this allowance record. Used by InsuranceRenewalScreen to link new documents to the correct application." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Applicant Name -->
        <attribute PhysicalName="va_applicantName">
          <Type>String</Type>
          <Name>va_applicantName</Name>
          <LogicalName>va_applicantName</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Recipient Name" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Applicant Job Title -->
        <attribute PhysicalName="va_applicantJobTitle">
          <Type>String</Type>
          <Name>va_applicantJobTitle</Name>
          <LogicalName>va_applicantJobTitle</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Job Title" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Applicant Company -->
        <attribute PhysicalName="va_applicantCompany">
          <Type>String</Type>
          <Name>va_applicantCompany</Name>
          <LogicalName>va_applicantCompany</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Company" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Next Renewal Due -->
        <attribute PhysicalName="va_nextRenewalDue">
          <Type>DateTime</Type>
          <Name>va_nextRenewalDue</Name>
          <LogicalName>va_nextRenewalDue</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Next Renewal Due" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Aug 1 of current or next year (whichever is ≥ 3 months away). Used by Home screen to show renewal deadline." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Termination Date -->
        <attribute PhysicalName="va_terminationDate">
          <Type>DateTime</Type>
          <Name>va_terminationDate</Name>
          <LogicalName>va_terminationDate</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Termination Date" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Termination Type (how the allowance ended) -->
        <attribute PhysicalName="va_terminationType">
          <Type>Picklist</Type>
          <Name>va_terminationType</Name>
          <LogicalName>va_terminationType</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Termination Type" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Distinguishes how the allowance was ended. Drives downstream actions (e.g., company car request vs. payroll stop only)." languagecode="1033" />
          </Descriptions>
          <optionset Name="va_allowanceterminationtype">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000410">
                <Labels><Label description="Employee Opt-Out — Company Car Requested" languagecode="1033" /></Labels>
                <Descriptions><Description description="MLT+ employee requested to return to a company vehicle. Company car assignment handled separately by Equipment Department." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000411">
                <Labels><Label description="Insurance Non-Compliance" languagecode="1033" /></Labels>
                <Descriptions><Description description="Policy lapsed or failed to meet requirements after grace period. Triggered automatically by Flow 7." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000412">
                <Labels><Label description="Administrative — Equipment Leader" languagecode="1033" /></Labels>
                <Descriptions><Description description="Terminated by Equipment Leader or Administrator (e.g., employee no longer eligible, role change, departure)." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000413">
                <Labels><Label description="Other" languagecode="1033" /></Labels>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- Termination Reason (free-text notes) -->
        <attribute PhysicalName="va_terminationReason">
          <Type>Memo</Type>
          <Name>va_terminationReason</Name>
          <LogicalName>va_terminationReason</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>2000</MaxLength>
          <Format>TextArea</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Termination Notes" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Additional context for the termination. Required when Termination Type is Administrative or Other." languagecode="1033" />
          </Descriptions>
        </attribute>

      </attributes>
    </entity>
  </EntityInfo>

  <!-- Relationships -->
  <EntityRelationships>
    <!-- va_allowancerecord → va_insurancepolicy (1:N) -->
    <EntityRelationship Name="va_allowancerecord_va_insurancepolicy">
      <EntityRelationshipType>OneToMany</EntityRelationshipType>
      <IsCustomizable>1</IsCustomizable>
      <ReferencingEntityName>va_insurancepolicy</ReferencingEntityName>
      <ReferencingAttributeName>va_allowanceRecordId</ReferencingAttributeName>
      <ReferencedEntityName>va_allowancerecord</ReferencedEntityName>
      <CascadeAssign>NoCascade</CascadeAssign>
      <CascadeDelete>NoCascade</CascadeDelete>
      <CascadeReparent>NoCascade</CascadeReparent>
      <CascadeShare>NoCascade</CascadeShare>
      <CascadeUnshare>NoCascade</CascadeUnshare>
    </EntityRelationship>
    <!-- va_allowancerecord → va_insurancereminderschedule (1:N) -->
    <EntityRelationship Name="va_allowancerecord_va_insurancereminderschedule">
      <EntityRelationshipType>OneToMany</EntityRelationshipType>
      <IsCustomizable>1</IsCustomizable>
      <ReferencingEntityName>va_insurancereminderschedule</ReferencingEntityName>
      <ReferencingAttributeName>va_allowanceRecordId</ReferencingAttributeName>
      <ReferencedEntityName>va_allowancerecord</ReferencedEntityName>
      <CascadeAssign>NoCascade</CascadeAssign>
      <CascadeDelete>Cascade</CascadeDelete>
      <CascadeReparent>NoCascade</CascadeReparent>
      <CascadeShare>NoCascade</CascadeShare>
      <CascadeUnshare>NoCascade</CascadeUnshare>
    </EntityRelationship>
  </EntityRelationships>

</Entity>
