<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name LocalizedName="Eligible Title" OriginalName="va_eligibletitle">va_eligibletitle</Name>
  <EntityInfo>
    <entity Name="va_eligibletitle">
      <LocalizedNames>
        <LocalizedName description="Eligible Title" languagecode="1033" />
      </LocalizedNames>
      <LocalizedCollectionNames>
        <LocalizedCollectionName description="Eligible Titles" languagecode="1033" />
      </LocalizedCollectionNames>
      <Descriptions>
        <Description description="Job titles eligible for the Vehicle Allowance Program, with their default allowance level. Pre-seeded by scripts/seed-reference-data.ps1. Queried by Flow 1 (via Fabric Lakehouse SQL) to validate applicant job title eligibility." languagecode="1033" />
      </Descriptions>
      <ownership>OrganizationOwned</ownership>
      <lookupcollectionname>va_eligibletitles</lookupcollectionname>
      <primaryattribute>va_name</primaryattribute>
      <IsActivity>0</IsActivity>
      <IsAuditEnabled>0</IsAuditEnabled>
      <IsAvailableOffline>0</IsAvailableOffline>
      <IsDocumentManagementEnabled>0</IsDocumentManagementEnabled>
      <IsQuickCreateEnabled>1</IsQuickCreateEnabled>
      <IsVisibleInMobile>0</IsVisibleInMobile>
      <attributes>

        <!-- Job Title -->
        <attribute PhysicalName="va_name">
          <Type>String</Type>
          <Name>va_name</Name>
          <LogicalName>va_name</LogicalName>
          <RequiredLevel>SystemRequired</RequiredLevel>
          <MaxLength>300</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Job Title" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Job title as it appears in Dynamics HR. Used for eligibility validation via Fabric Lakehouse SQL endpoint." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Default Allowance Level -->
        <attribute PhysicalName="va_defaultAllowanceLevel">
          <Type>Picklist</Type>
          <Name>va_defaultAllowanceLevel</Name>
          <LogicalName>va_defaultAllowanceLevel</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Default Allowance Level" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Maximum (ceiling) level for this title. Employee may select this level or any lower level. Displayed on EligibilityCheckScreen as the default recommendation." languagecode="1033" />
          </Descriptions>
          <optionset Name="va_allowancelevel">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- Is Active -->
        <attribute PhysicalName="va_isActive">
          <Type>Boolean</Type>
          <Name>va_isActive</Name>
          <LogicalName>va_isActive</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Is Active" languagecode="1033" />
          </LocalizedNames>
          <FalseOption>
            <Labels><Label description="Inactive — Not Eligible" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Active — Eligible" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

      </attributes>
    </entity>
  </EntityInfo>
</Entity>
