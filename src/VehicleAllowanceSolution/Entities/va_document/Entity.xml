<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name LocalizedName="Document" OriginalName="va_document">va_document</Name>
  <EntityInfo>
    <entity Name="va_document">
      <LocalizedNames>
        <LocalizedName description="Document" languagecode="1033" />
      </LocalizedNames>
      <LocalizedCollectionNames>
        <LocalizedCollectionName description="Documents" languagecode="1033" />
      </LocalizedCollectionNames>
      <Descriptions>
        <Description description="One row per uploaded file (insurance dec page, window sticker, endorsement). Contains the file reference column (va_fileReference) and AI extraction results. AI processing triggered by Flow 8 on row creation." languagecode="1033" />
      </Descriptions>
      <ownership>UserOwned</ownership>
      <lookupcollectionname>va_documents</lookupcollectionname>
      <primaryattribute>va_name</primaryattribute>
      <IsActivity>0</IsActivity>
      <IsAuditEnabled>1</IsAuditEnabled>
      <IsAvailableOffline>0</IsAvailableOffline>
      <IsDocumentManagementEnabled>0</IsDocumentManagementEnabled>
      <IsQuickCreateEnabled>0</IsQuickCreateEnabled>
      <IsVisibleInMobile>0</IsVisibleInMobile>
      <attributes>

        <!-- Primary Name (file name) -->
        <attribute PhysicalName="va_name">
          <Type>String</Type>
          <Name>va_name</Name>
          <LogicalName>va_name</LogicalName>
          <RequiredLevel>SystemRequired</RequiredLevel>
          <MaxLength>300</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Document Name" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Original file name of the uploaded document." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Document Type (set by va_DocumentClassifier, overridable by admin) -->
        <attribute PhysicalName="va_documentType">
          <Type>Picklist</Type>
          <Name>va_documentType</Name>
          <LogicalName>va_documentType</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Document Type" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_documenttype">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000300">
                <Labels><Label description="Auto Dec Page" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000301">
                <Labels><Label description="Umbrella Dec Page" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000302">
                <Labels><Label description="Window Sticker" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000303">
                <Labels><Label description="Endorsement" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000304">
                <Labels><Label description="Unknown" languagecode="1033" /></Labels>
                <Descriptions><Description description="Classification confidence below threshold — requires manual type assignment." languagecode="1033" /></Descriptions>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- AI Processing Status -->
        <attribute PhysicalName="va_aiProcessingStatus">
          <Type>Picklist</Type>
          <Name>va_aiProcessingStatus</Name>
          <LogicalName>va_aiProcessingStatus</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="AI Processing Status" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_aiprocessingstatus">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- AI Extracted Data (JSON blob from AI Builder) -->
        <attribute PhysicalName="va_aiExtractedData">
          <Type>Memo</Type>
          <Name>va_aiExtractedData</Name>
          <LogicalName>va_aiExtractedData</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>1048576</MaxLength>
          <Format>TextArea</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="AI Extracted Data" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="JSON blob containing all fields extracted by AI Builder. Parsed by Flow 2 to update InsurancePolicy or Vehicle records." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- AI Confidence Score -->
        <attribute PhysicalName="va_aiConfidenceScore">
          <Type>Decimal</Type>
          <Name>va_aiConfidenceScore</Name>
          <LogicalName>va_aiConfidenceScore</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1</MaxValue>
          <Precision>4</Precision>
          <LocalizedNames>
            <LocalizedName description="AI Confidence Score" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- AI Classification (raw classifier output) -->
        <attribute PhysicalName="va_aiClassification">
          <Type>String</Type>
          <Name>va_aiClassification</Name>
          <LogicalName>va_aiClassification</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>100</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="AI Classification" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Raw output from va_DocumentClassifier model before mapping to DocumentType picklist." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- File Reference (Dataverse file column) -->
        <attribute PhysicalName="va_fileReference">
          <Type>File</Type>
          <Name>va_fileReference</Name>
          <LogicalName>va_fileReference</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxSizeInKB>32768</MaxSizeInKB>
          <LocalizedNames>
            <LocalizedName description="File Reference" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="The uploaded file stored in Dataverse file storage. Uploaded via connectors.dataverse.uploadFile() in the code app. Accepted: PDF, JPG, PNG." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Uploaded By User ID -->
        <attribute PhysicalName="va_uploadedByUserId">
          <Type>String</Type>
          <Name>va_uploadedByUserId</Name>
          <LogicalName>va_uploadedByUserId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>100</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Uploaded By (User ID)" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="AAD Object ID of the user who uploaded this document. Used for column-level security: employees can only see documents they uploaded." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Uploaded On -->
        <attribute PhysicalName="va_uploadedOn">
          <Type>DateTime</Type>
          <Name>va_uploadedOn</Name>
          <LogicalName>va_uploadedOn</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateAndTime</Format>
          <LocalizedNames>
            <LocalizedName description="Uploaded On" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Application Lookup -->
        <attribute PhysicalName="va_applicationId">
          <Type>Lookup</Type>
          <Name>va_applicationId</Name>
          <LogicalName>va_applicationId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Application" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Linked Policy Lookup -->
        <attribute PhysicalName="va_linkedPolicyId">
          <Type>Lookup</Type>
          <Name>va_linkedPolicyId</Name>
          <LogicalName>va_linkedPolicyId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Linked Policy" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Linked Vehicle Lookup -->
        <attribute PhysicalName="va_linkedVehicleId">
          <Type>Lookup</Type>
          <Name>va_linkedVehicleId</Name>
          <LogicalName>va_linkedVehicleId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Linked Vehicle" languagecode="1033" />
          </LocalizedNames>
        </attribute>

      </attributes>
    </entity>
  </EntityInfo>
</Entity>
