<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name LocalizedName="Allowance Application" OriginalName="va_allowanceapplication">va_allowanceapplication</Name>
  <EntityInfo>
    <entity Name="va_allowanceapplication">
      <LocalizedNames>
        <LocalizedName description="Allowance Application" languagecode="1033" />
      </LocalizedNames>
      <LocalizedCollectionNames>
        <LocalizedCollectionName description="Allowance Applications" languagecode="1033" />
      </LocalizedCollectionNames>
      <Descriptions>
        <Description description="Central record for each Vehicle Allowance Program application (new opt-in, vehicle update, or annual renewal). Drives the full approval workflow." languagecode="1033" />
      </Descriptions>
      <ownership>UserOwned</ownership>
      <lookupcollectionname>va_allowanceapplications</lookupcollectionname>
      <primaryattribute>va_name</primaryattribute>
      <IsActivity>0</IsActivity>
      <IsAuditEnabled>1</IsAuditEnabled>
      <IsAvailableOffline>0</IsAvailableOffline>
      <IsDocumentManagementEnabled>0</IsDocumentManagementEnabled>
      <IsQuickCreateEnabled>0</IsQuickCreateEnabled>
      <IsVisibleInMobile>0</IsVisibleInMobile>
      <attributes>

        <!-- Primary Name -->
        <attribute PhysicalName="va_name">
          <Type>String</Type>
          <Name>va_name</Name>
          <LogicalName>va_name</LogicalName>
          <RequiredLevel>SystemRequired</RequiredLevel>
          <MaxLength>100</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Application Name" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Auto-generated application number in format VA-YYYY-NNNNN. Set by Flow 1 on submission." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Application Type -->
        <attribute PhysicalName="va_applicationType">
          <Type>Picklist</Type>
          <Name>va_applicationType</Name>
          <LogicalName>va_applicationType</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Application Type" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_applicationtype">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000000">
                <Labels><Label description="New Opt-In" languagecode="1033" /></Labels>
                <Descriptions><Description description="First-time enrollment in the vehicle allowance program." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000001">
                <Labels><Label description="Vehicle Update" languagecode="1033" /></Labels>
                <Descriptions><Description description="Updating vehicle details for an existing allowance recipient." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000002">
                <Labels><Label description="Annual Renewal" languagecode="1033" /></Labels>
                <Descriptions><Description description="Annual program renewal for existing allowance recipients." languagecode="1033" /></Descriptions>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- Status -->
        <attribute PhysicalName="va_status">
          <Type>Picklist</Type>
          <Name>va_status</Name>
          <LogicalName>va_status</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Status" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_applicationstatus">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000010">
                <Labels><Label description="Draft" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000011">
                <Labels><Label description="Submitted" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000012">
                <Labels><Label description="AI Review" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000013">
                <Labels><Label description="Equipment Leader Review" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000014">
                <Labels><Label description="Director Review" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000016">
                <Labels><Label description="Payroll Notification" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000017">
                <Labels><Label description="Active" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000018">
                <Labels><Label description="Rejected" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000019">
                <Labels><Label description="Returned to Employee" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000020">
                <Labels><Label description="Withdrawn" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000021">
                <Labels><Label description="Terminated" languagecode="1033" /></Labels>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- Allowance Level -->
        <attribute PhysicalName="va_allowanceLevel">
          <Type>Picklist</Type>
          <Name>va_allowanceLevel</Name>
          <LogicalName>va_allowanceLevel</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Allowance Level" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_allowancelevel">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- Effective Date -->
        <attribute PhysicalName="va_effectiveDate">
          <Type>DateTime</Type>
          <Name>va_effectiveDate</Name>
          <LogicalName>va_effectiveDate</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Effective Date" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Calculated by Flow 6: docs received on/before the 15th → current month 1st; 16th or later → next month 1st." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Monthly Allowance Amount -->
        <attribute PhysicalName="va_monthlyAllowanceAmount">
          <Type>Money</Type>
          <Name>va_monthlyAllowanceAmount</Name>
          <LogicalName>va_monthlyAllowanceAmount</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>10000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Monthly Allowance Amount" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- EV Charging Allowance -->
        <attribute PhysicalName="va_evChargingAllowance">
          <Type>Money</Type>
          <Name>va_evChargingAllowance</Name>
          <LogicalName>va_evChargingAllowance</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="EV Charging Allowance" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Additional $310/month for electric vehicle recipients." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Is Electric Vehicle -->
        <attribute PhysicalName="va_isElectricVehicle">
          <Type>Boolean</Type>
          <Name>va_isElectricVehicle</Name>
          <LogicalName>va_isElectricVehicle</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Is Electric Vehicle" languagecode="1033" />
          </LocalizedNames>
          <FalseOption>
            <Labels><Label description="No" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- Total Monthly Amount (base + EV charging) -->
        <attribute PhysicalName="va_totalMonthlyAmount">
          <Type>Money</Type>
          <Name>va_totalMonthlyAmount</Name>
          <LogicalName>va_totalMonthlyAmount</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>15000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Total Monthly Amount" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Monthly allowance + EV charging allowance (if applicable)." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- AI Validation Score -->
        <attribute PhysicalName="va_aiValidationScore">
          <Type>Decimal</Type>
          <Name>va_aiValidationScore</Name>
          <LogicalName>va_aiValidationScore</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>100</MaxValue>
          <Precision>1</Precision>
          <LocalizedNames>
            <LocalizedName description="AI Validation Score" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Composite AI confidence score 0-100. Scores ≥ threshold (env var va_AIAutoApprovalThreshold, default 75) qualify for fast-track routing." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- AI Auto-Approval Eligible -->
        <attribute PhysicalName="va_aiAutoApprovalEligible">
          <Type>Boolean</Type>
          <Name>va_aiAutoApprovalEligible</Name>
          <LogicalName>va_aiAutoApprovalEligible</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="AI Auto-Approval Eligible" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="True when AI score ≥ threshold AND all validation flags pass. Enables fast-track routing in Flow 3." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — AI Pre-Validated" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- Submitted On -->
        <attribute PhysicalName="va_submittedOn">
          <Type>DateTime</Type>
          <Name>va_submittedOn</Name>
          <LogicalName>va_submittedOn</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateAndTime</Format>
          <LocalizedNames>
            <LocalizedName description="Submitted On" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Personnel Number (from Dynamics/Fabric) -->
        <attribute PhysicalName="va_personnelNumber">
          <Type>String</Type>
          <Name>va_personnelNumber</Name>
          <LogicalName>va_personnelNumber</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>50</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Personnel Number" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Primary employee business key from Dynamics HR. Populated by eligibility check flow via Fabric Lakehouse SQL endpoint." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Applicant Company (legal entity) -->
        <attribute PhysicalName="va_applicantCompany">
          <Type>String</Type>
          <Name>va_applicantCompany</Name>
          <LogicalName>va_applicantCompany</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Applicant Company" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Legal entity / Clyde subsidiary from Dynamics. Determines which va_CompanyEntity record to use for insurance endorsement addressing." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Applicant Job Title -->
        <attribute PhysicalName="va_applicantJobTitle">
          <Type>String</Type>
          <Name>va_applicantJobTitle</Name>
          <LogicalName>va_applicantJobTitle</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Job Title" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Job title from Dynamics HR validated against va_EligibleTitle table." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Applicant Name -->
        <attribute PhysicalName="va_applicantName">
          <Type>String</Type>
          <Name>va_applicantName</Name>
          <LogicalName>va_applicantName</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Applicant Name" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Equipment Leader Decision -->
        <attribute PhysicalName="va_equipmentLeaderDecision">
          <Type>Picklist</Type>
          <Name>va_equipmentLeaderDecision</Name>
          <LogicalName>va_equipmentLeaderDecision</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Equipment Leader Decision" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_reviewerdecision">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- Equipment Leader Review Date -->
        <attribute PhysicalName="va_equipmentLeaderReviewDate">
          <Type>DateTime</Type>
          <Name>va_equipmentLeaderReviewDate</Name>
          <LogicalName>va_equipmentLeaderReviewDate</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateAndTime</Format>
          <LocalizedNames>
            <LocalizedName description="Equipment Leader Review Date" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Equipment Leader Notes (column-level security: hidden from Employee role) -->
        <attribute PhysicalName="va_equipmentLeaderNotes">
          <Type>Memo</Type>
          <Name>va_equipmentLeaderNotes</Name>
          <LogicalName>va_equipmentLeaderNotes</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>4000</MaxLength>
          <Format>TextArea</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Equipment Leader Notes" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Reviewer notes — returned with application or rejection. Column-level security hides from Employee role." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Director Decision -->
        <attribute PhysicalName="va_directorDecision">
          <Type>Picklist</Type>
          <Name>va_directorDecision</Name>
          <LogicalName>va_directorDecision</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Director Decision" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_reviewerdecision">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- Director Review Date -->
        <attribute PhysicalName="va_directorReviewDate">
          <Type>DateTime</Type>
          <Name>va_directorReviewDate</Name>
          <LogicalName>va_directorReviewDate</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateAndTime</Format>
          <LocalizedNames>
            <LocalizedName description="Director Review Date" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Director Notes -->
        <attribute PhysicalName="va_directorNotes">
          <Type>Memo</Type>
          <Name>va_directorNotes</Name>
          <LogicalName>va_directorNotes</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>4000</MaxLength>
          <Format>TextArea</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Director Notes" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Payroll Notified Date -->
        <attribute PhysicalName="va_payrollNotifiedDate">
          <Type>DateTime</Type>
          <Name>va_payrollNotifiedDate</Name>
          <LogicalName>va_payrollNotifiedDate</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateAndTime</Format>
          <LocalizedNames>
            <LocalizedName description="Payroll Notified Date" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- AI Extraction Summary (JSON) -->
        <attribute PhysicalName="va_aiExtractionSummary">
          <Type>Memo</Type>
          <Name>va_aiExtractionSummary</Name>
          <LogicalName>va_aiExtractionSummary</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>1048576</MaxLength>
          <Format>TextArea</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="AI Extraction Summary" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="JSON summary of all AI extraction results and validation flags for admin review." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Next Renewal Due -->
        <attribute PhysicalName="va_nextRenewalDue">
          <Type>DateTime</Type>
          <Name>va_nextRenewalDue</Name>
          <LogicalName>va_nextRenewalDue</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Next Renewal Due" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Set to Aug 1 of current or next year (whichever is ≥ 3 months away) when application is approved." languagecode="1033" />
          </Descriptions>
        </attribute>

      </attributes>
    </entity>
  </EntityInfo>

  <!-- Relationships -->
  <EntityRelationships>
    <!-- va_allowanceapplication → va_vehicle (1:N) -->
    <EntityRelationship Name="va_allowanceapplication_va_vehicle">
      <EntityRelationshipType>OneToMany</EntityRelationshipType>
      <IsCustomizable>1</IsCustomizable>
      <ReferencingEntityName>va_vehicle</ReferencingEntityName>
      <ReferencingAttributeName>va_applicationId</ReferencingAttributeName>
      <ReferencedEntityName>va_allowanceapplication</ReferencedEntityName>
      <CascadeAssign>NoCascade</CascadeAssign>
      <CascadeDelete>Cascade</CascadeDelete>
      <CascadeReparent>NoCascade</CascadeReparent>
      <CascadeShare>NoCascade</CascadeShare>
      <CascadeUnshare>NoCascade</CascadeUnshare>
    </EntityRelationship>
    <!-- va_allowanceapplication → va_insurancepolicy (1:N) -->
    <EntityRelationship Name="va_allowanceapplication_va_insurancepolicy">
      <EntityRelationshipType>OneToMany</EntityRelationshipType>
      <IsCustomizable>1</IsCustomizable>
      <ReferencingEntityName>va_insurancepolicy</ReferencingEntityName>
      <ReferencingAttributeName>va_applicationId</ReferencingAttributeName>
      <ReferencedEntityName>va_allowanceapplication</ReferencedEntityName>
      <CascadeAssign>NoCascade</CascadeAssign>
      <CascadeDelete>Cascade</CascadeDelete>
      <CascadeReparent>NoCascade</CascadeReparent>
      <CascadeShare>NoCascade</CascadeShare>
      <CascadeUnshare>NoCascade</CascadeUnshare>
    </EntityRelationship>
    <!-- va_allowanceapplication → va_document (1:N) -->
    <EntityRelationship Name="va_allowanceapplication_va_document">
      <EntityRelationshipType>OneToMany</EntityRelationshipType>
      <IsCustomizable>1</IsCustomizable>
      <ReferencingEntityName>va_document</ReferencingEntityName>
      <ReferencingAttributeName>va_applicationId</ReferencingAttributeName>
      <ReferencedEntityName>va_allowanceapplication</ReferencedEntityName>
      <CascadeAssign>NoCascade</CascadeAssign>
      <CascadeDelete>Cascade</CascadeDelete>
      <CascadeReparent>NoCascade</CascadeReparent>
      <CascadeShare>NoCascade</CascadeShare>
      <CascadeUnshare>NoCascade</CascadeUnshare>
    </EntityRelationship>
    <!-- va_allowanceapplication → va_documentchecklist (1:N) -->
    <EntityRelationship Name="va_allowanceapplication_va_documentchecklist">
      <EntityRelationshipType>OneToMany</EntityRelationshipType>
      <IsCustomizable>1</IsCustomizable>
      <ReferencingEntityName>va_documentchecklist</ReferencingEntityName>
      <ReferencingAttributeName>va_applicationId</ReferencingAttributeName>
      <ReferencedEntityName>va_allowanceapplication</ReferencedEntityName>
      <CascadeAssign>NoCascade</CascadeAssign>
