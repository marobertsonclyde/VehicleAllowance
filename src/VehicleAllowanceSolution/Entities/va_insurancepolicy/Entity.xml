<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name LocalizedName="Insurance Policy" OriginalName="va_insurancepolicy">va_insurancepolicy</Name>
  <EntityInfo>
    <entity Name="va_insurancepolicy">
      <LocalizedNames>
        <LocalizedName description="Insurance Policy" languagecode="1033" />
      </LocalizedNames>
      <LocalizedCollectionNames>
        <LocalizedCollectionName description="Insurance Policies" languagecode="1033" />
      </LocalizedCollectionNames>
      <Descriptions>
        <Description description="Insurance policy on file for an allowance application or active allowance record. The va_expirationDate column is the root trigger for Flow 7 (insurance expiry reminders). Multiple policies per application (Auto + Umbrella)." languagecode="1033" />
      </Descriptions>
      <ownership>UserOwned</ownership>
      <lookupcollectionname>va_insurancepolicies</lookupcollectionname>
      <primaryattribute>va_name</primaryattribute>
      <IsActivity>0</IsActivity>
      <IsAuditEnabled>1</IsAuditEnabled>
      <IsAvailableOffline>0</IsAvailableOffline>
      <IsDocumentManagementEnabled>0</IsDocumentManagementEnabled>
      <IsQuickCreateEnabled>0</IsQuickCreateEnabled>
      <IsVisibleInMobile>0</IsVisibleInMobile>
      <attributes>

        <!-- Primary Name -->
        <attribute PhysicalName="va_name">
          <Type>String</Type>
          <Name>va_name</Name>
          <LogicalName>va_name</LogicalName>
          <RequiredLevel>SystemRequired</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Policy Name" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Display name formatted as: PolicyType — Carrier — PolicyNumber (e.g., Auto — State Farm — 1234567)." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Policy Type -->
        <attribute PhysicalName="va_policyType">
          <Type>Picklist</Type>
          <Name>va_policyType</Name>
          <LogicalName>va_policyType</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Policy Type" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_insurancepolicytype">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000200">
                <Labels><Label description="Auto" languagecode="1033" /></Labels>
                <Descriptions><Description description="Personal auto liability policy. Must meet CSL or split limits." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000201">
                <Labels><Label description="Umbrella" languagecode="1033" /></Labels>
                <Descriptions><Description description="Umbrella/excess liability policy. Must meet minimum umbrella limits." languagecode="1033" /></Descriptions>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- Carrier Name -->
        <attribute PhysicalName="va_carrierName">
          <Type>String</Type>
          <Name>va_carrierName</Name>
          <LogicalName>va_carrierName</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Carrier Name" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Policy Number -->
        <attribute PhysicalName="va_policyNumber">
          <Type>String</Type>
          <Name>va_policyNumber</Name>
          <LogicalName>va_policyNumber</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MaxLength>100</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Policy Number" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Policy Effective Date -->
        <attribute PhysicalName="va_effectiveDate">
          <Type>DateTime</Type>
          <Name>va_effectiveDate</Name>
          <LogicalName>va_effectiveDate</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Policy Effective Date" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Policy Expiration Date (drives Flow 7 reminders) -->
        <attribute PhysicalName="va_expirationDate">
          <Type>DateTime</Type>
          <Name>va_expirationDate</Name>
          <LogicalName>va_expirationDate</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <Format>DateOnly</Format>
          <LocalizedNames>
            <LocalizedName description="Expiration Date" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="CRITICAL: This date drives the insurance reminder schedule (Flow 7). When updated via Insurance Renewal screen, Flow 7 creates new va_InsuranceReminderSchedule rows." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Combined Single Limit (Auto) -->
        <attribute PhysicalName="va_cslLimit">
          <Type>Money</Type>
          <Name>va_cslLimit</Name>
          <LogicalName>va_cslLimit</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>100000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="CSL Limit" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Combined Single Limit. Auto policy requirement: CSL ≥ $500,000 OR split limits (BI/PD). Extracted by AI Builder from dec page." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Bodily Injury Per Person -->
        <attribute PhysicalName="va_bodilyInjuryPerPerson">
          <Type>Money</Type>
          <Name>va_bodilyInjuryPerPerson</Name>
          <LogicalName>va_bodilyInjuryPerPerson</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>100000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Bodily Injury — Per Person" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Split limit: BI per person. Requirement: ≥ $250,000." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Bodily Injury Per Accident -->
        <attribute PhysicalName="va_bodilyInjuryPerAccident">
          <Type>Money</Type>
          <Name>va_bodilyInjuryPerAccident</Name>
          <LogicalName>va_bodilyInjuryPerAccident</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>100000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Bodily Injury — Per Accident" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Split limit: BI per accident. Requirement: ≥ $500,000." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Property Damage -->
        <attribute PhysicalName="va_propertyDamage">
          <Type>Money</Type>
          <Name>va_propertyDamage</Name>
          <LogicalName>va_propertyDamage</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>100000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Property Damage" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Split limit: property damage. Requirement: ≥ $100,000." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Umbrella Limit -->
        <attribute PhysicalName="va_umbrellaLimit">
          <Type>Money</Type>
          <Name>va_umbrellaLimit</Name>
          <LogicalName>va_umbrellaLimit</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>100000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Umbrella Limit" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Umbrella/excess limit. Requirement: ≥ $1M (Additional Insured) or ≥ $2M (Additional Interest)." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Endorsement Type -->
        <attribute PhysicalName="va_endorsementType">
          <Type>Picklist</Type>
          <Name>va_endorsementType</Name>
          <LogicalName>va_endorsementType</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Endorsement Type" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_endorsementtype">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000210">
                <Labels><Label description="Additional Insured" languagecode="1033" /></Labels>
                <Descriptions><Description description="Clyde subsidiary listed as Additional Insured. Umbrella minimum: $1M." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000211">
                <Labels><Label description="Additional Interest" languagecode="1033" /></Labels>
                <Descriptions><Description description="Clyde subsidiary listed as Additional Interest. Umbrella minimum: $2M." languagecode="1033" /></Descriptions>
              </Option>
              <Option Value="720000212">
                <Labels><Label description="None" languagecode="1033" /></Labels>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- Endorsed Entity Name (must match va_CompanyEntity) -->
        <attribute PhysicalName="va_endorsedEntityName">
          <Type>String</Type>
          <Name>va_endorsedEntityName</Name>
          <LogicalName>va_endorsedEntityName</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>300</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Endorsed Entity Name" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Name of the entity on the endorsement. AI validates via fuzzy match against 8 va_CompanyEntity records." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Meets Liability Requirement -->
        <attribute PhysicalName="va_meetsLiabilityRequirement">
          <Type>Boolean</Type>
          <Name>va_meetsLiabilityRequirement</Name>
          <LogicalName>va_meetsLiabilityRequirement</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Meets Liability Requirement" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Set by Flow 2. True if CSL ≥ $500K OR (BI/person ≥ $250K AND BI/accident ≥ $500K AND PD ≥ $100K)." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No — Does Not Meet Requirements" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — Meets Requirements" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- Meets Umbrella Requirement -->
        <attribute PhysicalName="va_meetsUmbrellaRequirement">
          <Type>Boolean</Type>
          <Name>va_meetsUmbrellaRequirement</Name>
          <LogicalName>va_meetsUmbrellaRequirement</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Meets Umbrella Requirement" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Set by Flow 2. True if umbrella limit meets the threshold for the endorsement type (≥$1M for Additional Insured, ≥$2M for Additional Interest)." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No — Does Not Meet Requirements" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — Meets Requirements" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- AI Confidence Score -->
        <attribute PhysicalName="va_aiConfidenceScore">
          <Type>Decimal</Type>
          <Name>va_aiConfidenceScore</Name>
          <LogicalName>va_aiConfidenceScore</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1</MaxValue>
          <Precision>4</Precision>
          <LocalizedNames>
            <LocalizedName description="AI Confidence Score" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Personnel Number -->
        <attribute PhysicalName="va_personnelNumber">
          <Type>String</Type>
          <Name>va_personnelNumber</Name>
          <LogicalName>va_personnelNumber</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>50</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Personnel Number" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Employee PersonnelNumber from Dynamics. Stored here for use in Flow 7 reminder targeting when allowance record is the primary context." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Is Active Policy -->
        <attribute PhysicalName="va_isActivePolicy">
          <Type>Boolean</Type>
          <Name>va_isActivePolicy</Name>
          <LogicalName>va_isActivePolicy</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Is Active Policy" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="True for policies linked to an active AllowanceRecord. Used by Insurance Renewal screen and Flow 7." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — Active" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- Application Lookup -->
        <attribute PhysicalName="va_applicationId">
          <Type>Lookup</Type>
          <Name>va_applicationId</Name>
          <LogicalName>va_applicationId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Application" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Allowance Record Lookup -->
        <attribute PhysicalName="va_allowanceRecordId">
          <Type>Lookup</Type>
          <Name>va_allowanceRecordId</Name>
          <LogicalName>va_allowanceRecordId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Allowance Record" languagecode="1033" />
          </LocalizedNames>
        </attribute>

      </attributes>
    </entity>
  </EntityInfo>
</Entity>
