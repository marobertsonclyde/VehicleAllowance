<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name LocalizedName="Vehicle" OriginalName="va_vehicle">va_vehicle</Name>
  <EntityInfo>
    <entity Name="va_vehicle">
      <LocalizedNames>
        <LocalizedName description="Vehicle" languagecode="1033" />
      </LocalizedNames>
      <LocalizedCollectionNames>
        <LocalizedCollectionName description="Vehicles" languagecode="1033" />
      </LocalizedCollectionNames>
      <Descriptions>
        <Description description="Vehicle details associated with an allowance application. One vehicle per application. VIN, MSRP, year, and body type are extracted by AI Builder from the window sticker document." languagecode="1033" />
      </Descriptions>
      <ownership>UserOwned</ownership>
      <lookupcollectionname>va_vehicles</lookupcollectionname>
      <primaryattribute>va_name</primaryattribute>
      <IsActivity>0</IsActivity>
      <IsAuditEnabled>1</IsAuditEnabled>
      <IsAvailableOffline>0</IsAvailableOffline>
      <IsDocumentManagementEnabled>0</IsDocumentManagementEnabled>
      <IsQuickCreateEnabled>0</IsQuickCreateEnabled>
      <IsVisibleInMobile>0</IsVisibleInMobile>
      <attributes>

        <!-- Primary Name (Year Make Model) -->
        <attribute PhysicalName="va_name">
          <Type>String</Type>
          <Name>va_name</Name>
          <LogicalName>va_name</LogicalName>
          <RequiredLevel>SystemRequired</RequiredLevel>
          <MaxLength>200</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Vehicle" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Display name formatted as Year Make Model (e.g., 2024 Ford F-150). Set when VIN details are entered." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- VIN -->
        <attribute PhysicalName="va_vin">
          <Type>String</Type>
          <Name>va_vin</Name>
          <LogicalName>va_vin</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MaxLength>17</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="VIN" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="17-character Vehicle Identification Number. Extracted from window sticker by AI Builder or entered manually." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Make -->
        <attribute PhysicalName="va_make">
          <Type>String</Type>
          <Name>va_make</Name>
          <LogicalName>va_make</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MaxLength>100</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Make" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Model -->
        <attribute PhysicalName="va_model">
          <Type>String</Type>
          <Name>va_model</Name>
          <LogicalName>va_model</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MaxLength>100</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Model" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- Year -->
        <attribute PhysicalName="va_year">
          <Type>Integer</Type>
          <Name>va_year</Name>
          <LogicalName>va_year</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MinValue>2000</MinValue>
          <MaxValue>2100</MaxValue>
          <Format>None</Format>
          <LocalizedNames>
            <LocalizedName description="Year" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Model year. Must be within 5 years of current year. Validated by Flow 2." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Body Type -->
        <attribute PhysicalName="va_bodyType">
          <Type>Picklist</Type>
          <Name>va_bodyType</Name>
          <LogicalName>va_bodyType</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Body Type" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_vehiclebodytype">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>0</IsGlobal>
            <Options>
              <Option Value="720000100">
                <Labels><Label description="Sedan" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000101">
                <Labels><Label description="SUV" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000102">
                <Labels><Label description="Truck" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000103">
                <Labels><Label description="Van" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000104">
                <Labels><Label description="Coupe" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000105">
                <Labels><Label description="Wagon" languagecode="1033" /></Labels>
              </Option>
              <Option Value="720000106">
                <Labels><Label description="Other" languagecode="1033" /></Labels>
              </Option>
            </Options>
          </optionset>
        </attribute>

        <!-- MSRP Base -->
        <attribute PhysicalName="va_msrpBase">
          <Type>Money</Type>
          <Name>va_msrpBase</Name>
          <LogicalName>va_msrpBase</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="MSRP Base Price" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- MSRP Packages -->
        <attribute PhysicalName="va_msrpPackages">
          <Type>Money</Type>
          <Name>va_msrpPackages</Name>
          <LogicalName>va_msrpPackages</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>500000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="MSRP Packages &amp; Options" languagecode="1033" />
          </LocalizedNames>
        </attribute>

        <!-- MSRP Total (bottom of window sticker) -->
        <attribute PhysicalName="va_msrpTotal">
          <Type>Money</Type>
          <Name>va_msrpTotal</Name>
          <LogicalName>va_msrpTotal</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1000000</MaxValue>
          <Precision>2</Precision>
          <PrecisionSource>2</PrecisionSource>
          <LocalizedNames>
            <LocalizedName description="Total MSRP" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Total MSRP from bottom of Monroney window sticker. Determines eligible allowance level(s)." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Is Electric Vehicle -->
        <attribute PhysicalName="va_isElectricVehicle">
          <Type>Boolean</Type>
          <Name>va_isElectricVehicle</Name>
          <LogicalName>va_isElectricVehicle</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Is Electric Vehicle" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Detected from window sticker powertrain field. Enables $310/month EV charging allowance. No fuel card issued for EV recipients." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — Electric Vehicle" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- Dynamics Asset ID -->
        <attribute PhysicalName="va_dynamicsAssetId">
          <Type>String</Type>
          <Name>va_dynamicsAssetId</Name>
          <LogicalName>va_dynamicsAssetId</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MaxLength>50</MaxLength>
          <Format>Text</Format>
          <ImeMode>auto</ImeMode>
          <LocalizedNames>
            <LocalizedName description="Dynamics Asset ID" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Asset ID from Dynamics 365 Fixed Assets module. Entered manually by admin after application approval; automated integration deferred to future phase." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Pre-Approval Confirmed -->
        <attribute PhysicalName="va_preApprovalConfirmed">
          <Type>Boolean</Type>
          <Name>va_preApprovalConfirmed</Name>
          <LogicalName>va_preApprovalConfirmed</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Pre-Approval Confirmed" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="Employee checkbox confirming their vehicle was pre-approved or already purchased. Required before submission." languagecode="1033" />
          </Descriptions>
          <FalseOption>
            <Labels><Label description="No" languagecode="1033" /></Labels>
          </FalseOption>
          <TrueOption>
            <Labels><Label description="Yes — Confirmed" languagecode="1033" /></Labels>
          </TrueOption>
        </attribute>

        <!-- AI Processing Status -->
        <attribute PhysicalName="va_aiProcessingStatus">
          <Type>Picklist</Type>
          <Name>va_aiProcessingStatus</Name>
          <LogicalName>va_aiProcessingStatus</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="AI Processing Status" languagecode="1033" />
          </LocalizedNames>
          <optionset Name="va_aiprocessingstatus">
            <OptionSetType>picklist</OptionSetType>
            <IsGlobal>1</IsGlobal>
          </optionset>
        </attribute>

        <!-- AI Confidence Score -->
        <attribute PhysicalName="va_aiConfidenceScore">
          <Type>Decimal</Type>
          <Name>va_aiConfidenceScore</Name>
          <LogicalName>va_aiConfidenceScore</LogicalName>
          <RequiredLevel>None</RequiredLevel>
          <MinValue>0</MinValue>
          <MaxValue>1</MaxValue>
          <Precision>4</Precision>
          <LocalizedNames>
            <LocalizedName description="AI Confidence Score" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="AI Builder extraction confidence 0.0–1.0. Below 0.70 flags for human review." languagecode="1033" />
          </Descriptions>
        </attribute>

        <!-- Application Lookup -->
        <attribute PhysicalName="va_applicationId">
          <Type>Lookup</Type>
          <Name>va_applicationId</Name>
          <LogicalName>va_applicationId</LogicalName>
          <RequiredLevel>ApplicationRequired</RequiredLevel>
          <LocalizedNames>
            <LocalizedName description="Application" languagecode="1033" />
          </LocalizedNames>
        </attribute>

      </attributes>
    </entity>
  </EntityInfo>
</Entity>
