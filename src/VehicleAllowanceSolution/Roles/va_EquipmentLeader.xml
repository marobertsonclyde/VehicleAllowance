<?xml version="1.0" encoding="utf-8"?>
<!--
  Security Role: va_EquipmentLeader
  Audience: Company Equipment Leader (the primary reviewer for all applications).
  AAD Group: va-equipment-leaders

  Access pattern: Org-wide read on all application data. Write access to decision fields
  and the ability to terminate AllowanceRecords (opt-out / admin termination).

  This role does NOT inherit va_Employee directly in Dataverse — the AAD group assignment
  ensures Equipment Leaders also have the Employee role if they are personally eligible.
  Configure both roles for equipment leader users who are also eligible employees.

  Key responsibilities:
  - First reviewer in the approval chain (Equipment Leader Review step)
  - Can terminate active AllowanceRecords (company car request, non-compliance, admin)
  - Receives urgent Teams notifications when insurance policies expire
  - Can re-upload or reprocess documents on behalf of employees
-->
<Role uniquename="va_EquipmentLeader">
  <LocalizedNames>
    <LocalizedName description="Vehicle Allowance — Equipment Leader" languagecode="1033" />
  </LocalizedNames>
  <Descriptions>
    <Description description="Equipment Leader reviewer role. Org-wide read on all application data; write access to decision fields and AllowanceRecord termination." languagecode="1033" />
  </Descriptions>
  <IsInherited>1</IsInherited>
  <RolePrivileges>

    <!-- va_AllowanceApplication: Org-wide read; write decision + notes fields -->
    <RolePrivilege name="prvCreateva_allowanceapplication"   level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvReadva_allowanceapplication"     level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvWriteva_allowanceapplication"    level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvAppendva_allowanceapplication"   level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvAppendTova_allowanceapplication" level="Global" privilegeobjecttypecode="va_allowanceapplication" />

    <!-- va_Vehicle: Org-wide read -->
    <RolePrivilege name="prvCreateva_vehicle"   level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvReadva_vehicle"     level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvWriteva_vehicle"    level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvAppendva_vehicle"   level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvAppendTova_vehicle" level="Global" privilegeobjecttypecode="va_vehicle" />

    <!-- va_InsurancePolicy: Org-wide read/write (update policy details, mark active) -->
    <RolePrivilege name="prvCreateva_insurancepolicy"   level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvReadva_insurancepolicy"     level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvWriteva_insurancepolicy"    level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvAppendva_insurancepolicy"   level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvAppendTova_insurancepolicy" level="Global" privilegeobjecttypecode="va_insurancepolicy" />

    <!-- va_Document: Org-wide read (can view all uploaded docs); write for reprocessing -->
    <RolePrivilege name="prvCreateva_document"   level="Global" privilegeobjecttypecode="va_document" />
    <RolePrivilege name="prvReadva_document"     level="Global" privilegeobjecttypecode="va_document" />
    <RolePrivilege name="prvWriteva_document"    level="Global" privilegeobjecttypecode="va_document" />
    <RolePrivilege name="prvAppendva_document"   level="Global" privilegeobjecttypecode="va_document" />
    <RolePrivilege name="prvAppendTova_document" level="Global" privilegeobjecttypecode="va_document" />

    <!-- va_DocumentChecklist: Org-wide read/write -->
    <RolePrivilege name="prvReadva_documentchecklist"     level="Global" privilegeobjecttypecode="va_documentchecklist" />
    <RolePrivilege name="prvWriteva_documentchecklist"    level="Global" privilegeobjecttypecode="va_documentchecklist" />
    <RolePrivilege name="prvAppendva_documentchecklist"   level="Global" privilegeobjecttypecode="va_documentchecklist" />
    <RolePrivilege name="prvAppendTova_documentchecklist" level="Global" privilegeobjecttypecode="va_documentchecklist" />

    <!-- va_AllowanceRecord: Org-wide read/write (termination action) -->
    <RolePrivilege name="prvCreateva_allowancerecord"   level="Global" privilegeobjecttypecode="va_allowancerecord" />
    <RolePrivilege name="prvReadva_allowancerecord"     level="Global" privilegeobjecttypecode="va_allowancerecord" />
    <RolePrivilege name="prvWriteva_allowancerecord"    level="Global" privilegeobjecttypecode="va_allowancerecord" />
    <RolePrivilege name="prvAppendva_allowancerecord"   level="Global" privilegeobjecttypecode="va_allowancerecord" />
    <RolePrivilege name="prvAppendTova_allowancerecord" level="Global" privilegeobjecttypecode="va_allowancerecord" />

    <!-- Reference tables: Global read -->
    <RolePrivilege name="prvReadva_companyentity"      level="Global" privilegeobjecttypecode="va_companyentity" />
    <RolePrivilege name="prvReadva_eligibletitle"      level="Global" privilegeobjecttypecode="va_eligibletitle" />
    <RolePrivilege name="prvReadva_allowancelevelconfig" level="Global" privilegeobjecttypecode="va_allowancelevelconfig" />

    <!-- va_AuditLog: Org-wide read -->
    <RolePrivilege name="prvReadva_auditlog"     level="Global" privilegeobjecttypecode="va_auditlog" />
    <RolePrivilege name="prvWriteva_auditlog"    level="Global" privilegeobjecttypecode="va_auditlog" />
    <RolePrivilege name="prvCreateva_auditlog"   level="Global" privilegeobjecttypecode="va_auditlog" />

    <!-- va_Notification: Read org-wide -->
    <RolePrivilege name="prvReadva_notification" level="Global" privilegeobjecttypecode="va_notification" />

    <!-- va_InsuranceReminderSchedule: Read/write (can manually trigger or reset reminders) -->
    <RolePrivilege name="prvReadva_insurancereminderschedule"  level="Global" privilegeobjecttypecode="va_insurancereminderschedule" />
    <RolePrivilege name="prvWriteva_insurancereminderschedule" level="Global" privilegeobjecttypecode="va_insurancereminderschedule" />

    <!-- va_ReminderConfig: Read (admin configures, Equipment Leader reads) -->
    <RolePrivilege name="prvReadva_reminderconfig" level="Global" privilegeobjecttypecode="va_reminderconfig" />

  </RolePrivileges>
</Role>
