<?xml version="1.0" encoding="utf-8"?>
<!--
  Security Role: va_Administrator
  Audience: System administrators and Equipment Department system managers.
  AAD Group: va-administrators

  Access pattern: Full CRUD on all tables at Global level. Also has access to
  reference data management (CompanyEntity presidents, EligibleTitles, AllowanceLevelConfig,
  ReminderConfig) which are hidden from other roles.

  Key responsibilities:
  - Seed and maintain reference data (company entities, eligible titles, level configs)
  - Configure per-company president User IDs (va_CompanyEntity.va_presidentUserId)
  - Configure reminder schedule intervals (va_ReminderConfig)
  - Migrate existing allowance recipients from SharePoint (data migration screen in admin app)
  - Enter Dynamics Asset IDs on va_Vehicle records after approval
  - Resolve AI processing failures and reprocess documents
  - Manage AAD group membership (via Azure AD portal, not this app)
-->
<Role uniquename="va_Administrator">
  <LocalizedNames>
    <LocalizedName description="Vehicle Allowance — Administrator" languagecode="1033" />
  </LocalizedNames>
  <Descriptions>
    <Description description="System administrator role. Full CRUD on all tables. Manages reference data, president assignments, reminder configuration, and data migration." languagecode="1033" />
  </Descriptions>
  <IsInherited>1</IsInherited>
  <RolePrivileges>

    <!-- Full CRUD on all custom tables at Global level -->

    <!-- va_AllowanceApplication -->
    <RolePrivilege name="prvCreateva_allowanceapplication"   level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvReadva_allowanceapplication"     level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvWriteva_allowanceapplication"    level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvDeleteva_allowanceapplication"   level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvAppendva_allowanceapplication"   level="Global" privilegeobjecttypecode="va_allowanceapplication" />
    <RolePrivilege name="prvAppendTova_allowanceapplication" level="Global" privilegeobjecttypecode="va_allowanceapplication" />

    <!-- va_Vehicle -->
    <RolePrivilege name="prvCreateva_vehicle"   level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvReadva_vehicle"     level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvWriteva_vehicle"    level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvDeleteva_vehicle"   level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvAppendva_vehicle"   level="Global" privilegeobjecttypecode="va_vehicle" />
    <RolePrivilege name="prvAppendTova_vehicle" level="Global" privilegeobjecttypecode="va_vehicle" />

    <!-- va_InsurancePolicy -->
    <RolePrivilege name="prvCreateva_insurancepolicy"   level="Global" privilegeobjecttypecode="va_insurancepolicy" />
