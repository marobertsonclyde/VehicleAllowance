    <RolePrivilege name="prvWriteva_insurancepolicy"    level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvDeleteva_insurancepolicy"   level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvAppendva_insurancepolicy"   level="Global" privilegeobjecttypecode="va_insurancepolicy" />
    <RolePrivilege name="prvAppendTova_insurancepolicy" level="Global" privilegeobjecttypecode="va_insurancepolicy" />

    <!-- va_Document -->
    <RolePrivilege name="prvCreateva_document"   level="Global" privilegeobjecttypecode="va_document" />
    <RolePrivilege name="prvReadva_document"     level="Global" privilegeobjecttypecode="va_document" />
    <RolePrivilege name="prvWriteva_document"    level="Global" privilegeobjecttypecode="va_document" />
