    <RolePrivilege name="prvAppendTova_insurancereminderschedule" level="Global" privilegeobjecttypecode="va_insurancereminderschedule" />

    <!-- va_ReminderConfig (admin manages: reminder intervals, grace period) -->
    <RolePrivilege name="prvCreateva_reminderconfig"   level="Global" privilegeobjecttypecode="va_reminderconfig" />
    <RolePrivilege name="prvReadva_reminderconfig"     level="Global" privilegeobjecttypecode="va_reminderconfig" />
