# ─── Packed solution output ───────────────────────────────────────────────────
out/

# ─── AI model training data (PII — stored in SharePoint, not git) ─────────────
training-data/*
!training-data/.gitkeep

# ─── Environment-specific secrets (never commit production values) ─────────────
config/prod-environment-variables.json

# ─── PAC CLI auth cache ────────────────────────────────────────────────────────
.pac/

# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor artifacts ─────────────────────────────────────────────────────────
.vscode/settings.json
*.swp
*.swo

# ─── PowerShell ───────────────────────────────────────────────────────────────
*.ps1.bak

# ─── Node / code app ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
apps/*/dist/
apps/*/.vite/
*.tsbuildinfo
apps/*/vite.config.js
apps/*/vite.config.d.ts
apps/*/vitest.config.js
apps/*/vitest.config.d.ts

# Generated Dataverse service files (created by: pac code add-data-source)
# Commit these once generated — they are the typed API layer.
# Listed here as a reminder that they don't exist until PAC CLI creates them.
# apps/employee-portal/src/generated/models/*.ts
# apps/employee-portal/src/generated/services/*.ts

# ─── Temporary export ZIPs (in case someone runs export into repo root) ────────
*.zip
!out/*.zip
